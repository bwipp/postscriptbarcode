# Example packaging has no changelog entries
addFilter("no-changelogname-tag")

# postscriptbarcode is a data-only package (PostScript resource files)
addFilter("postscriptbarcode\.\S+: E: no-binary")

# Doxygen CSS contains build timestamp
addFilter("file-contains-date-and-time.*/doxygen\.css")

# Doxygen HTML docs are the bulk of the libs package
addFilter("package-with-huge-docs")
