/hanxin dup /uk.co.terryburton.bwipp findresource cvx def

%
% Codewords+ECC check: debugcws is emitted after ECC generation and block
% reassembly, so the array is interleaved data + ECC. v10-L4 spans the
% e1 and e2 block groups.
%
{
    (ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789) (version=10 eclevel=L4 debugcws) hanxin
} [
    48 166 111 116 79 26 227 166 49 0 0 0 18 38 3 22 170 155 94 147 96 0 0 0
    32 167 185 155 42 27 83 94 0 0 0 0 161 39 43 7 171 156 148 234 0 0 0 0
    33 168 119 121 43 28 234 127 0 0 0 0 162 40 21 88 172 128 212 10 0 0 0 0
    34 169 225 66 44 0 94 121 0 0 0 0 163 41 247 110 173 0 20 170 0 0 0 0
    35 202 228 228 24 0 71 50 0 0 0 0 164 48 107 193 24 81 121 149 0 0 0 0
    36 72 35 145 153 214 25 127 0 0 0 0 165 84 117 218 25 10 148 74 0 0 0 0
    37 27 128 204 154 122 140 4 0 0 0 0
] debugIsEqual

% ECC check: flat concat of per-block ECC codewords (ecwsb).
{
    (ABC123) (version=1 eclevel=L4 debugecc) hanxin
} [51 128 84 236 129 14 174 77 89 104 57 137 129 140 72 175] debugIsEqual

% ECC check: v28 L4 spans all three block groups (e1nb=10, e2nb=3, e3nb=1).
/hx28data 240 string def 0 1 239 { hx28data exch 65 put } for
{
    hx28data (version=28 eclevel=L4 debugecc) hanxin
} [
    29 96 73 61 110 158 75 187 183 201 82 27 175 70 21 120 90 181 185 20
    85 234 110 111 71 13 24 169 67 12 150 222 163 191 199 168 21 105 118 234
    22 231 226 14 63 33 2 18 96 28 161 251 24 169 67 12 150 222 163 191
    199 168 21 105 118 234 22 231 226 14 63 33 2 18 96 28 161 251 24 169
    67 12 150 222 163 191 199 168 21 105 118 234 22 231 226 14 63 33 2 18
    96 28 161 251 24 169 67 12 150 222 163 191 199 168 21 105 118 234 22 231
    226 14 63 33 2 18 96 28 161 251 24 169 67 12 150 222 163 191 199 168
    21 105 118 234 22 231 226 14 63 33 2 18 96 28 161 251 24 169 67 12
    150 222 163 191 199 168 21 105 118 234 22 231 226 14 63 33 2 18 96 28
    161 251 24 169 67 12 150 222 163 191 199 168 21 105 118 234 22 231 226 14
    63 33 2 18 96 28 161 251 24 169 67 12 150 222 163 191 199 168 21 105
    118 234 22 231 226 14 63 33 2 18 96 28 161 251 24 169 67 12 150 222
    163 191 199 168 21 105 118 234 22 231 226 14 63 33 2 18 96 28 161 251
    194 147 234 184 129 108 230 74 112 255 6 129 138 253 155 200 89 28 21 144
    198 20 130 56 208 129 190 129 194 147 234 184 129 108 230 74 112 255 6 129
    138 253 155 200 89 28 21 144 198 20 130 56 208 129 190 129 194 147 234 184
    129 108 230 74 112 255 6 129 138 253 155 200 89 28 21 144 198 20 130 56
    208 129 190 129 181 19 175 42 111 243 157 243 37 185 53 119 228 154 23 73
    126 251 90 113 97 26 141 70 155 52 242 68
] debugIsEqual

/er_tmpl {
    3 1 roll { 0 0 hanxin }
    dup 3 -1 roll 1 exch put
    dup 3 -1 roll 0 exch put
    exch isError
} def


