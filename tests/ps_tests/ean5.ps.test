/ean5 dup /uk.co.terryburton.bwipp findresource cvx def

{ (90200) (dontdraw) ean5 /sbs get
} [ 1 1 2 2 1 1 3 1 1 3 2 1 1 1 1 2 1 2 2 1 1 3 2 1 1 1 1 1 1 2 3 ] debugIsEqual


%
% Error tests
%

{ (1234) (dontdraw) ean5 } /bwipp.ean5badLength isError
{ (ABCDE) (dontdraw) ean5 } /bwipp.ean5badCharacter isError


%
% Smoke test: propspec and physspec render without error
%
/ok_tmpl {
    { 0 0 moveto 0 0 ean5 true } dup 3 -1 roll 4 exch put dup 3 -1 roll 3 exch put
    true isEqual
} def
(90200)  (includetext propspec)   ok_tmpl
(90200)  (includetext physspec xdim=0.330)   ok_tmpl
