% Barcode Writer in Pure PostScript
% https://bwipp.terryburton.co.uk
%
% vim: set sw=4 sts=4 et:
%
% Copyright (c) 2004-2025 Terry Burton
%

/itf14 dup /uk.co.terryburton.bwipp findresource cvx def

{ (0 952 1234 54321 3) (dontdraw) itf14 /sbs get
} [ 1 1 1 1 1 1 1 2 2 1 2 2 1 1 2 1 1 2 2 1 1 1 1 2 2 1 1 2 1 1 1 1 2 2 2 1 2 1 1 2 1 1 1 2 2 1 1 1 2 2 1 1 1 2 2 1 2 2 1 1 1 1 1 2 2 2 1 2 1 1 1 1 2 1 2 1 1 1 ] debugIsEqual


%
% Error tests
%

{ (123456789012) (dontdraw) itf14 } /bwipp.itf14badLength isError
{ (123456789012345) (dontdraw) itf14 } /bwipp.itf14badLength isError
{ (095212345432A3) (dontdraw) itf14 } /bwipp.itf14badCharacter isError
{ (09521234543210) (dontdraw) itf14 } /bwipp.itf14badCheckDigit isError

%
% AST bounds: xdim below xmin (0.495) fails
%
{ (0952876543210) (dontdraw physspec xdim=0.400) itf14 } /bwipp.renderXdimTooSmall isError

%
% AST bounds: xdim above xmax (1.016) fails
%
{ (0952876543210) (dontdraw physspec xdim=1.100) itf14 } /bwipp.renderXdimTooLarge isError

%
% AST bounds: xdim within bounds succeeds
%
{ 0 0 moveto (0952876543210) (physspec xdim=0.600) itf14 true } true isEqual

%
% propspec: height derived from AST hnom/xnom through wrapper
% hnom=31.75 xnom=0.495: round(31.75/0.495)=64, 64/72=0.8889
%
{
    (0952876543210) (dontdraw propspec) itf14 /bhs get 0 get 1 array astore
} [0.8889] isEqual

%
% physspec without explicit xdim resolves from AST xnom (0.495)
%
{
    (0952876543210) (dontdraw physspec) itf14 dup /physspec get exch /xdim get 2 array astore
} [true 0.495] isEqual

%
% propspec with user height override: user height wins
%
{
    (0952876543210) (dontdraw propspec height=0.3) itf14 /bhs get 0 get 1 array astore
} [0.3] isEqual

% AST consumption: SST profile resolves through wrapper
{ (0952876543210) (dontdraw physspec ast=gs1.sst2) itf14 dup /physspec get exch /xdim get 2 array astore } [true 0.495] isEqual

%
% bestfit: output matches physspec through wrapper
%
/uk.co.terryburton.bwipp.global_ctx << /enabledebug true /enabledontdraw true /bestfit true >> def
{ (0952876543210) (dontdraw) itf14 dup /physspec get exch /xdim get 2 array astore } [true 0.495] isEqual
{ (0952876543210) (dontdraw) itf14 /bhs get 0 get 1 array astore } [0.8909] isEqual
/uk.co.terryburton.bwipp.global_ctx << /enabledebug true /enabledontdraw true >> def

%
% physspec mag through wrapper: mag consumed at outer layer
%
{ 0 0 moveto (0952876543210) (physspec mag=1.5) itf14 true } true isEqual

%
% ast consumed: does not leak to interleaved2of5
% (interleaved2of5 would error on ast=gs1.sst2 if it leaked)
%
{ 0 0 moveto (0952876543210) (ast=gs1.sst2) itf14 true } true isEqual

%
% bestfit + mag + gridfit through wrapper
%
{ 0 0 moveto (0952876543210) (bestfit mag=3 gridfit griddpi=72) itf14 true } true isEqual
