% height option affects only linear bars, not the CC component
{
    (331234567890|(99)1234-abcd) (dontdraw ccversion=a height=0.5) ean13composite
    dup /height get exch /pixy get 72 div sub abs 0.001 lt  % height = pixy/72 (natural, not user's 0.5)
} true isEqual

% Missing composite component (no pipe character)
{ (331234567890) (dontdraw) ean13composite } /bwipp.missingCompositeComponent isError

% AST bounds: xdim below xmin fails
{ (\(01\)09521234543213|\(21\)A1B2C3D4E5F6G7H8) (dontdraw physspec xdim=0.200) ean13composite } /bwipp.renderXdimTooSmall isError

% physspec smoke test
{ 0 0 moveto (9520123456788|\(21\)A1B2C3D4E5F6G7H8) (physspec) ean13composite true } true isEqual

% physspec with SST smoke test
{ 0 0 moveto (9520123456788|\(21\)A1B2C3D4E5F6G7H8) (physspec) ean13composite true } true isEqual

% propspec with SST smoke test
{ 0 0 moveto (9520123456788|\(21\)A1B2C3D4E5F6G7H8) (propspec) ean13composite true } true isEqual

%
% physspec: xdim resolves from default AST xnom through composite → ean13
%
{
    (9520123456788|\(21\)A1B2C3D4E5F6G7H8) (dontdraw physspec) ean13composite
    dup /physspec get exch /xdim get 2 array astore
} [true 0.330] isEqual

%
% bestfit: output matches physspec through composite
%
/tmp uk.co.terryburton.bwipp.global_ctx def
/tmp uk.co.terryburton.bwipp.global_ctx def
/uk.co.terryburton.bwipp.global_ctx << /enabledebug true /enabledontdraw true /bestfit true >> def
{ (9520123456788|\(21\)A1B2C3D4E5F6G7H8) (dontdraw) ean13composite dup /physspec get exch /xdim get 2 array astore } [true 0.330] isEqual
/uk.co.terryburton.bwipp.global_ctx tmp def

%
% ast consumed: does not leak to gs1-cc/micropdf417
% (micropdf417 would error on ast=gs1.sst2 if it leaked)
%
{ 0 0 moveto (9520123456788|\(21\)A1B2C3D4E5F6G7H8) (ast=gs1.sst2) ean13composite true } true isEqual


%
% bestfit via global_ctx: does not leak to gs1-cc (would error on missing xnom)
%
/tmp uk.co.terryburton.bwipp.global_ctx def
/uk.co.terryburton.bwipp.global_ctx << /enabledebug true /enabledontdraw true /bestfit true >> def
{ 0 0 moveto (9520123456788|\(21\)A1B2C3D4E5F6G7H8) () ean13composite true } true isEqual
/uk.co.terryburton.bwipp.global_ctx tmp def
