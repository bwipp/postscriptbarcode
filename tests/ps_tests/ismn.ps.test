/ismn dup /uk.co.terryburton.bwipp findresource cvx def

{ (979-0-2605-3211-3) (dontdraw) ismn /sbs get
} [ 1 1 1 1 3 1 2 2 1 1 3 1 1 2 3 2 1 2 2 4 1 1 1 3 2 1 1 1 1 1 1 1 1 2 3 1 1 4 1 1 2 1 2 2 2 2 2 1 2 2 2 1 1 4 1 1 1 1 1 ] debugIsEqual


%
% Error tests
%

{ (979-0-2605-321) (dontdraw) ismn } /bwipp.ismnBadLength isError
{ (979-0-2605-3211-3 123) (dontdraw) ismn } /bwipp.ismnBadAddOnLength isError
{ (978-0-2605-3211-5) (dontdraw) ismn } /bwipp.ismn13badPrefix isError
{ (979-0--605-3211-3) (dontdraw) ismn } /bwipp.ismn13adjacentDashes isError
{ (979-0-260532114-3) (dontdraw) ismn } /bwipp.ismn13numDashesDigits isError
{ (979-0-2605-321A-3) (dontdraw) ismn } /bwipp.ismn13character15 isError
{ (979-0-2605-321133) (dontdraw) ismn } /bwipp.ismn13character16 isError
{ (979-0-2605-3211-A) (dontdraw) ismn } /bwipp.ismn13character17 isError
{ (979-0-2605-3211-0) (dontdraw) ismn } /bwipp.ismnBadCheckDigit isError
{ (X-2605-3211-4) (dontdraw) ismn } /bwipp.ismn10badPrefix isError
{ (M-A605-3211-4) (dontdraw) ismn } /bwipp.ismn10character3 isError
{ (M-2--5-3211-4) (dontdraw) ismn } /bwipp.ismn10adjacentDashes isError
{ (M-260532110-4) (dontdraw) ismn } /bwipp.ismn10numDashesDigits isError
{ (M-2605-321A-4) (dontdraw) ismn } /bwipp.ismn10character11 isError
{ (M-2605-321144) (dontdraw) ismn } /bwipp.ismn10character12 isError
{ (M-2605-3211-?) (dontdraw) ismn } /bwipp.ismn10character13 isError

% AST bounds: xdim below xmin fails
{ (979-0-2605-3211-3) (dontdraw strictspec xdim=0.200) ismn } /bwipp.renderXdimTooSmall isError

% propspec smoke test
{ 0 0 moveto (979-0-2605-3211-3) (propspec) ismn true } true isEqual

%
% Label text migrated to text2 framework
%

% Default ISMN label is populated as text2 content
{ (979-0-2605-3211-3) (dontdraw includetext) ismn /opt get (text2) get } (ISMN 979-0-2605-3211-3) isEqual

% text2 absent when includetext is off
{ (979-0-2605-3211-3) (dontdraw) ismn /opt get (text2) known 1 array astore } [false] isEqual

% Default xoffset is -12.0 for full-form ISMN-13 label
{ (979-0-2605-3211-3) (dontdraw includetext) ismn /opt get (text2xoffset) get 1 array astore } [-12.0] isEqual

% Default xoffset is -1.0 for legacy ISMN-10 label (shorter)
{ (M-2605-3211-3) (dontdraw includetext legacy) ismn /opt get (text2xoffset) get 1 array astore } [-1.0] isEqual

% User overrides label content via text2=
{ (979-0-2605-3211-3) (dontdraw includetext text2=CUSTOM) ismn /opt get (text2) get } (CUSTOM) isEqual

% extratext alias overrides label content
{ (979-0-2605-3211-3) (dontdraw includetext extratext=Alt) ismn /opt get (text2) get } (Alt) isEqual

% ismntext legacy alias overrides label content
{ (979-0-2605-3211-3) (dontdraw includetext ismntext=Legacy) ismn /opt get (text2) get } (Legacy) isEqual

% Legacy ismntextfont alias flows to text2font
{ (979-0-2605-3211-3) (dontdraw includetext ismntextfont=Helvetica) ismn /opt get (text2font) get } (Helvetica) isEqual

% User-set xalign opts out of default xoffset injection
{ (979-0-2605-3211-3) (dontdraw includetext text2xalign=center) ismn /opt get (text2xoffset) known 1 array astore } [false] isEqual

% xoffset is preserved when user supplies it alongside non-default xalign
{ (979-0-2605-3211-3) (dontdraw includetext text2xalign=center text2xoffset=42) ismn /opt get (text2xoffset) get 1 array astore } [42.0] isEqual

% Smoke test: extratextcolor renders without error
{ 0 0 moveto (979-0-2605-3211-3) (includetext extratextcolor=FF0000) ismn true } true isEqual
