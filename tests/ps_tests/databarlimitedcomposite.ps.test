{ (\(01\)09521234543213) (dontdraw) databarlimitedcomposite } /bwipp.missingCompositeComponent isError

%
% Smoke test: physspec renders without error
%
/ok_tmpl {
    { 0 0 moveto 0 0 databarlimitedcomposite true } dup 3 -1 roll 4 exch put dup 3 -1 roll 3 exch put
    true isEqual
} def
(\(01\)09521234543213|\(21\)abcdefghijklmnopqrst)  (physspec xdim=0.330)  ok_tmpl

% AST bounds: xdim below xmin fails
{ (\(01\)09521234543213|\(21\)abcdefghijklmnopqrst) (dontdraw physspec xdim=0.100) databarlimitedcomposite } /bwipp.renderXdimTooSmall isError

% physspec with SST smoke test
{ 0 0 moveto (\(01\)09521234543213|\(21\)abcdefghijklmnopqrst) (physspec ast=gs1.sst2) databarlimitedcomposite true } true isEqual

% propspec with SST smoke test
{ 0 0 moveto (\(01\)09521234543213|\(21\)abcdefghijklmnopqrst) (propspec ast=gs1.sst2) databarlimitedcomposite true } true isEqual


%
% bestfit via global_ctx: does not leak to gs1-cc (would error on missing xnom)
%
/tmp uk.co.terryburton.bwipp.global_ctx def
/uk.co.terryburton.bwipp.global_ctx << /enabledebug true /enabledontdraw true /bestfit true >> def
{ 0 0 moveto (\(01\)09521234543213|\(21\)abcdefghijklmnopqrst) () databarlimitedcomposite true } true isEqual
/uk.co.terryburton.bwipp.global_ctx tmp def
