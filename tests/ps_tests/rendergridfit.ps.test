% Barcode Writer in Pure PostScript
% https://bwipp.terryburton.co.uk
%
% vim: set sw=4 sts=4 et:
%
% Copyright (c) 2004-2026 Terry Burton
%

/render dup /uk.co.terryburton.bwipp findresource cvx def

%
% Smoke test: simple round, no spec bounds, uniform scaling
%
{ gsave 0 0 moveto 10 dict begin /loosespec false def /griddpi 300 def 1 0 -1 -1 false false /gridfit render end grestore } true isEqual

%
% Smoke test: simple round, no spec bounds, independent y
%
{ gsave 0 0 moveto 10 dict begin /loosespec false def /griddpi 300 def 1 0 -1 -1 false true /gridfit render end grestore } true isEqual

%
% Smoke test: floor mode, no spec bounds, uniform scaling
%
{ gsave 0 0 moveto 10 dict begin /loosespec false def /griddpi 300 def 1 0 -1 -1 true false /gridfit render end grestore } true isEqual

%
% Smoke test: even magnitude, no spec bounds, uniform (MaxiCode)
%
{ gsave 0 0 moveto 10 dict begin /loosespec false def /griddpi 300 def 2 0 -1 -1 false false /gridfit render end grestore } true isEqual

%
% Smoke test: auto-detect (griddpi=0, nullpage disables)
%
{ gsave 0 0 moveto 10 dict begin /loosespec false def /griddpi 0 def 1 0 -1 -1 false false /gridfit render end grestore } true isEqual

%
% Smoke test: spec bounds, within range
%
{ gsave 0 0 moveto 10 dict begin /loosespec false def /griddpi 300 def 1 0.330 0.264 0.660 false false /gridfit render end grestore } true isEqual

%
% Smoke test: spec bounds, no min/max
%
{ gsave 0 0 moveto 10 dict begin /loosespec false def /griddpi 300 def 1 0.330 -1 -1 false false /gridfit render end grestore } true isEqual

%
% Round goes below xmin, ceiling saves it
% 300 DPI: xdim=0.280 -> 3.307 dev px, round=3, eff=0.254 < xmin=0.260; ceil=4, eff=0.339 OK
%
{ gsave 0 0 moveto 10 dict begin /loosespec false def /griddpi 300 def 1 0.280 0.260 0.400 false false /gridfit render end grestore } true isEqual

%
% Round goes above xmax, floor saves it
% 200 DPI: xdim=0.380 -> 2.992 dev px, round=3, eff=0.381 > xmax=0.379; floor=2, eff=0.254 OK
%
{ gsave 0 0 moveto 10 dict begin /loosespec false def /griddpi 200 def 1 0.380 0.200 0.379 false false /gridfit render end grestore } true isEqual

%
% Gridfit out of spec: impossibly tight bounds
%
% Returns errorname on failure: check it
%
{ gsave 0 0 moveto 10 dict begin /loosespec false def /griddpi 300 def 1 0.330 0.3295 0.3305 false false /gridfit render end
  not { pop grestore } if  % Discard info string, grestore
} /bwipp.renderGridfitXdimOutOfSpec isEqual

%
% snapy=true must mirror the x-axis retry direction so square matrix
% symbols (QR, Data Matrix, Aztec, ...) stay square.  The three cases
% below exercise each xsnapmode outcome and assert scale_x == scale_y
% by comparing |dtransform(1,0)| against |dtransform(0,1)| after gridfit.
% Dev-px calculations assume the test device's 72 DPI resolution so
% devpx = griddpi / 72 per user unit.
%
% snapy=true + ceiling retry (xsnapmode=2)
% griddpi=300: devpx=4.167, round=4 eff=0.288 < xmin=0.295, frac=0.167 <0.5
% so retry picks ceiling=5 eff=0.360 within [0.295, 0.400].  y must
% also snap to 5 rather than its independent round=4.
%
{ gsave 0 0 moveto 10 dict begin /loosespec false def /griddpi 300 def 1 0.300 0.295 0.400 false true /gridfit render
  { 1 0 dtransform abs exch abs add 0 1 dtransform abs exch abs add sub abs 0.0001 lt }
  { pop false } ifelse
  end grestore } true isEqual

%
% snapy=true + floor retry (xsnapmode=1)
% griddpi=200: devpx=2.778, round=3 eff=0.410 > xmax=0.379, frac=0.778 >=0.5
% so retry picks floor=2 eff=0.274 within [0.200, 0.379].  y must
% also snap to 2 rather than its independent round=3.
%
{ gsave 0 0 moveto 10 dict begin /loosespec false def /griddpi 200 def 1 0.380 0.200 0.379 false true /gridfit render
  { 1 0 dtransform abs exch abs add 0 1 dtransform abs exch abs add sub abs 0.0001 lt }
  { pop false } ifelse
  end grestore } true isEqual

%
% snapy=true + loosespec revert to snap1 (xsnapmode reset to 0)
% griddpi=300: devpx=4.167, round=4 eff=0.288 < xmin=0.295 fail,
% retry ceiling=5 eff=0.360 > xmax=0.350 fail.  loosespec picks closer:
% dist(0.288)=0.007 < dist(0.360)=0.010, so snap1 (round=4) wins and
% xsnapmode must reset to 0 so y also rounds to 4, not stay at ceil=5.
%
{ gsave 0 0 moveto 10 dict begin /loosespec true def /griddpi 300 def 1 0.300 0.295 0.350 false true /gridfit render
  { 1 0 dtransform abs exch abs add 0 1 dtransform abs exch abs add sub abs 0.0001 lt }
  { pop false } ifelse
  end grestore } true isEqual
