% Barcode Writer in Pure PostScript
% https://bwipp.terryburton.co.uk
%
% vim: set sw=4 sts=4 et:
%
% Copyright (c) 2004-2026 Terry Burton
%

/onecode dup /uk.co.terryburton.bwipp findresource cvx def

%
%
% 20-digit barcode (exercises different startvals code path)
%
{ (01234567094987654321) (debugcws) onecode } [ 0 0 0 0 559 202 508 451 124 34 ] debugIsEqual

%
% 25-digit barcode
%
{ (0123456709498765432112345) (debugcws) onecode } [ 659 0 150 72 109 1016 535 1063 167 578 ] debugIsEqual

%
% 29-digit barcode
%
{ (01234567094987654321123456789) (debugcws) onecode } [ 0 1100 201 601 240 505 309 189 728 906 ] debugIsEqual

%
% 31-digit edge case: all 9s maximizes carry propagation
%
{ (9999999999999999999999999999999) (debugcws) onecode } [ 658 1133 256 291 361 249 330 1102 394 270 ] debugIsEqual


%
% Error tests
%

{ (0123456709498765432A) (dontdraw) onecode } /bwipp.onecodeBadCharacter isError
{ (012345670949876543210123456789) (dontdraw) onecode } /bwipp.onecodeInvalidLength isError


%
% Smoke test: strictspec renders without error
%
/ok_tmpl {
    { 0 0 moveto 0 0 onecode true } dup 3 -1 roll 4 exch put dup 3 -1 roll 3 exch put
    true isEqual
} def
(0123456709498765432101234567891)  (strictspec)  ok_tmpl

% AST bounds: xdim below xmin fails
{ (0123456709498765432101234567891) (dontdraw strictspec xdim=0.300) onecode } /bwipp.renderXdimTooSmall isError

%
% propspec: height derived from AST hnom/xnom, pixel-locked
% hnom=3.683 xnom=0.508: round(3.683/0.508)=7, 7/72=0.0972
% bhs[0] is 5*height/8 for ascender bar
%
{ (0123456709498765432101234567891) (dontdraw) onecode /bhs get 0 get 1 array astore } [0.0938] isEqual
{ (0123456709498765432101234567891) (dontdraw propspec) onecode /bhs get 0 get 1 array astore } [0.0608] isEqual
