% Barcode Writer in Pure PostScript
% https://bwipp.terryburton.co.uk
%
% vim: set sw=4 sts=4 et:
%
% Copyright (c) 2004-2026 Terry Burton
%

/pharmacode dup /uk.co.terryburton.bwipp findresource cvx def

{ (117480) (dontdraw) pharmacode /sbs get
} [ 3 2 3 2 1 2 1 2 3 2 1 2 3 2 1 2 3 2 3 2 3 2 1 2 3 2 1 2 1 2 3 2 ] debugIsEqual


%
% Error tests
%

{ () (dontdraw) pharmacode } /bwipp.pharmacodeBadLength isError
{ (1234567) (dontdraw) pharmacode } /bwipp.pharmacodeBadLength isError
{ (12A4) (dontdraw) pharmacode } /bwipp.pharmacodeBadCharacter isError
{ (2) (dontdraw) pharmacode } /bwipp.pharmacodeBadValue isError
{ (131071) (dontdraw) pharmacode } /bwipp.pharmacodeBadValue isError


%
% Smoke test: propspec and strictspec render without error
%
/ok_tmpl {
    { 0 0 moveto 0 0 pharmacode true } dup 3 -1 roll 4 exch put dup 3 -1 roll 3 exch put
    true isEqual
} def
(117480)  (showborder propspec)   ok_tmpl
(117480)  (showborder strictspec)   ok_tmpl

%
% propspec: height derived from AST hnom/xnom, pixel-locked
% hnom=8.000 xnom=0.500: round(8.000/0.500)=16, 16/72=0.2222
%
{ (117480) (dontdraw) pharmacode /bhs get 0 get 1 array astore } [1.0] isEqual
{ (117480) (dontdraw propspec) pharmacode /bhs get 0 get 1 array astore } [0.2222] isEqual

% propspec + user height: user wins
{ (117480) (dontdraw propspec height=0.5) pharmacode /bhs get 0 get 1 array astore } [0.5] isEqual
