} [64] isEqual

%
% propspec without hnom (default AST): linear bar height falls back to 0.5 inches = 36pt
%
{
    (\(00\)095287654321012346|\(02\)09521234543213\(37\)24\(10\)1234567ABCDEFG) (dontdraw ccversion=c propspec) gs1-128composite
    /rowmult get dup length 1 sub get
    1 array astore
} [36] isEqual
