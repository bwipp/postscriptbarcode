% Missing composite component (no pipe character)
{ (12345670) (dontdraw) ean8composite } /bwipp.missingCompositeComponent isError

%
% Smoke test: physspec renders without error
%
/ok_tmpl {
    { 0 0 moveto 0 0 ean8composite true } dup 3 -1 roll 4 exch put dup 3 -1 roll 3 exch put
    true isEqual
} def
(95200002|\(21\)A12345678)  (physspec xdim=0.330)  ok_tmpl

% AST bounds: xdim below xmin fails
{ (\(01\)03612345678904|\(21\)A1B2C3D4E5F6G7H8) (dontdraw physspec xdim=0.200) ean8composite } /bwipp.renderXdimTooSmall isError

% physspec with SST smoke test
{ 0 0 moveto (95200002|\(21\)A12345678) (physspec) ean8composite true } true isEqual

% propspec with SST smoke test
{ 0 0 moveto (95200002|\(21\)A12345678) (propspec) ean8composite true } true isEqual

%
% physspec mag through composite: mag consumed at outer layer, no leak to inner
%
{ 0 0 moveto (95200002|\(21\)A12345678) (physspec mag=2) ean8composite true } true isEqual

%
% bestfit + mag + gridfit through composite
%
{
    (95200002|\(21\)A12345678) (dontdraw bestfit mag=3 gridfit griddpi=72) ean8composite
    dup /physspec get exch /bestfit get 2 array astore
} [true true] isEqual


%
% bestfit via global_ctx: does not leak to gs1-cc (would error on missing xnom)
%
/tmp uk.co.terryburton.bwipp.global_ctx def
/uk.co.terryburton.bwipp.global_ctx << /enabledebug true /enabledontdraw true /bestfit true >> def
{ 0 0 moveto (95200002|\(21\)A12345678) () ean8composite true } true isEqual
/uk.co.terryburton.bwipp.global_ctx tmp def
