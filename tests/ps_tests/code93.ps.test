% AIM USS Code 93 AIM-BC5-2000


/code93 dup /uk.co.terryburton.bwipp findresource cvx def

/eq_tmpl {
    exch { 0 (dontdraw includecheck) code93 /sbs get } dup 3 -1 roll 0 exch put
    exch isEqual
} def


% Non-shifts $/+%

($/+%)
    [1 1 1 1 4 1 3 2 1 1 1 1 1 1 2 1 3 1 1 1 3 1 2 1 2 1 1 1 3 1 1 2 1 1 2 2 1 1 1 2 2 2 1 1 1 1 4 1 1] eq_tmpl


%
% Error tests
%

{ (abc) (dontdraw) code93 } /bwipp.code93BadCharacter isError

{ 501 string (dontdraw) code93 } /bwipp.code93inputTooLong isError

%
% Smoke test: propspec renders without error
%
/ok_tmpl {
    { 0 0 moveto 0 0 code93 true } dup 3 -1 roll 4 exch put dup 3 -1 roll 3 exch put
    true isEqual
} def
(THIS IS CODE 93)  (propspec)  ok_tmpl

% strictspec smoke test
{ 0 0 moveto (THIS IS CODE 93) (strictspec xdim=0.330) code93 true } true isEqual
