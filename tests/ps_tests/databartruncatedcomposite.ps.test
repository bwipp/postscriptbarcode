%
% Smoke test: physspec renders without error
%
/ok_tmpl {
    { 0 0 moveto 0 0 databartruncatedcomposite true } dup 3 -1 roll 4 exch put dup 3 -1 roll 3 exch put
    true isEqual
} def
(\(01\)09521234543213|\(11\)990102)  (physspec xdim=0.330)  ok_tmpl

% AST bounds: xdim below xmin fails
{ (\(01\)09521234543213|\(11\)990102) (dontdraw physspec xdim=0.100) databartruncatedcomposite } /bwipp.renderXdimTooSmall isError

% physspec with SST smoke test
{ 0 0 moveto (\(01\)09521234543213|\(11\)990102) (physspec ast=gs1.sst4) databartruncatedcomposite true } true isEqual

% propspec with SST smoke test
{ 0 0 moveto (\(01\)09521234543213|\(11\)990102) (propspec ast=gs1.sst4) databartruncatedcomposite true } true isEqual


