%
% Error tests
%

% Invalid rows (valid: 5+)
(TEST) (rows=4 dontdraw) /bwipp.dotcodeBadRows er_tmpl

% Invalid columns (valid: 5+)
(TEST) (columns=4 dontdraw) /bwipp.dotcodeBadColumns er_tmpl

% Rows + columns must be odd
(TEST) (rows=6 columns=6 dontdraw) /bwipp.dotcodeRowsColumnsBadParity er_tmpl

% Invalid ratio
(TEST) (ratio=0 dontdraw) /bwipp.dotcodeRatio er_tmpl

% Invalid mask (valid: 0-3)
(TEST) (mask=4 dontdraw) /bwipp.dotcodeBadMask er_tmpl

% Data too long
{ 500 string 0 1 499 { 1 index exch 65 put } for (rows=5 columns=6 dontdraw) dotcode } /bwipp.dotcodeTooLong isError

4001 string (dontdraw) /bwipp.dotcodeinputTooLong er_tmpl

(TEST) (columns=0 dontdraw) /bwipp.dotcodeBadColumns er_tmpl
(TEST) (columns=1 dontdraw) /bwipp.dotcodeBadColumns er_tmpl
(TEST) (columns=2 dontdraw) /bwipp.dotcodeBadColumns er_tmpl
{ (TEST) (columns=5 dontdraw) dotcode pop true } true isEqual
(TEST) (rows=0 dontdraw) /bwipp.dotcodeBadRows er_tmpl
(TEST) (rows=1 dontdraw) /bwipp.dotcodeBadRows er_tmpl
{ (TEST) (columns=200 dontdraw) dotcode pop true } true isEqual

% ECI range
{ (^ECI000000TEST) (parsefnc dontdraw) dotcode pop true } true isEqual
{ (^ECI999999TEST) (parsefnc dontdraw) dotcode pop true } true isEqual

% strictspec smoke test
{ 0 0 moveto (This is DotCode) (strictspec xdim=0.330) dotcode true } true isEqual
