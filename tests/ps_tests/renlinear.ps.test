{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /extratextxoffset 151 >> >> renlinear } /bwipp.extratextBadxoffset isError

{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /extratextyoffset -151 >> >> renlinear } /bwipp.extratextBadyoffset isError
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /extratextyoffset 151 >> >> renlinear } /bwipp.extratextBadyoffset isError

{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /extratextgaps -21 >> >> renlinear } /bwipp.extratextBadgaps isError
