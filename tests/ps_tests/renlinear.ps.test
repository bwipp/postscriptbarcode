%
% text3-9 options and validation
%

% text3 rendering
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /text3 (EXTRA) >> >> renlinear true } true isEqual

% text3 with font/alignment options
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /text3 (HELLO) /text3font (Helvetica) /text3xalign /center /text3yalign /below >> >> renlinear true } true isEqual

% text3 validation errors
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /text3xalign /invalid >> >> renlinear } /bwipp.text3Badxalign isError
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /text3yalign /invalid >> >> renlinear } /bwipp.text3Badyalign isError
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /text3direction /invalid >> >> renlinear } /bwipp.text3Baddirection isError
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /text3size 0 >> >> renlinear } /bwipp.text3Badsize isError
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /text3xoffset -151 >> >> renlinear } /bwipp.text3Badxoffset isError
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /text3yoffset 151 >> >> renlinear } /bwipp.text3Badyoffset isError
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /text3gaps -21 >> >> renlinear } /bwipp.text3Badgaps isError
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /text3linegaps -1 >> >> renlinear } /bwipp.text3Badlinegaps isError

% text9 validation (highest group)
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /text9xalign /invalid >> >> renlinear } /bwipp.text9Badxalign isError

% text3 rendertext errors (justify)
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /text3 (TEST) /text3xalign /justify /text3direction /upward >> >> renlinear } /bwipp.text3xjustify isError
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /text3 (TEST) /text3yalign /justify /text3direction /forward >> >> renlinear } /bwipp.text3yjustify isError

% Alias backward compatibility: alttext => text1
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /includetext true /alttext (TEST) /textxalign /center >> >> renlinear true } true isEqual

% Alias backward compatibility: extratext => text2
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /extratext (EXTRA) >> >> renlinear true } true isEqual

% Alias: alttextsubspace => text1subspace
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /includetext true /alttext (A_B) /alttextsubspace (_) >> >> renlinear true } true isEqual

% Alias: alttextsplit => text1split
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /includetext true /alttext (A|B) /alttextsplit (|) >> >> renlinear true } true isEqual

% Primary name: text1subspace
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /includetext true /alttext (A_B) /text1subspace (_) >> >> renlinear true } true isEqual

% Primary name: text1split
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /includetext true /alttext (A|B) /text1split (|) >> >> renlinear true } true isEqual

% text1=hello activates text1 without includetext
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /text1 (DIRECT) >> >> renlinear true } true isEqual

% alttext=hello activates text1 without includetext
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /alttext (DIRECT) >> >> renlinear true } true isEqual

% includetext enables encoder txt (fast path)
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /txt [ [ (X) 0 0 (Courier) 10 ] ] /opt << /includetext true >> >> renlinear true } true isEqual

% Multiple text groups simultaneously
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /text1 (ONE) /text3 (THREE) /text5 (FIVE) >> >> renlinear true } true isEqual

% text9 rendering (highest group)
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /text9 (NINE) >> >> renlinear true } true isEqual

