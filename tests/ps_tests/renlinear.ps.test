{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /borderwidth -1 >> >> renlinear } /bwipp.renlinearBadBorderwidth isError
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /borderwidth 11 >> >> renlinear } /bwipp.renlinearBadBorderwidth isError

{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /textxoffset -151 >> >> renlinear } /bwipp.textBadxoffset isError
{ 0 0 moveto << /ren /renlinear /sbs [1] /bhs [1] /bbs [0] /opt << /textxoffset 151 >> >> renlinear } /bwipp.textBadxoffset isError

