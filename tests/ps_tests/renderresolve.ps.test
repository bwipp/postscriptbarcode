% Barcode Writer in Pure PostScript
% https://bwipp.terryburton.co.uk
%
% vim: set sw=4 sts=4 et:
%
% Copyright (c) 2004-2026 Terry Burton
%

/render dup /uk.co.terryburton.bwipp findresource cvx def
/raiseerror dup /uk.co.terryburton.bwipp findresource cvx def

%
% resolve_strictspec: strictspec=false is a no-op
%
{
    10 dict begin
    /strictspec false def /propspec false def /loosespec false def /mag 1.0 def /xdim -1.0 def /hdim -1.0 def
    /xnom 0.330 def /hnom 22.85 def /xmin 0.264 def /xmax 0.660 def
    /resolve_strictspec render
    xdim 1 array astore
    end
} [-1.0] isEqual

%
% resolve_strictspec: resolves xdim from xnom * mag
%
{
    10 dict begin
    /strictspec true def /propspec false def /loosespec false def /mag 1.0 def /xdim -1.0 def /hdim -1.0 def
    /xnom 0.330 def /hnom 22.85 def /xmin 0.264 def /xmax 0.660 def
    /resolve_strictspec render
    xdim 1 array astore
    end
} [0.330] isEqual

%
% resolve_strictspec: resolves xdim with mag=2.0
%
{
    10 dict begin
    /strictspec true def /propspec false def /loosespec false def /mag 2.0 def /xdim -1.0 def /hdim -1.0 def
    /xnom 0.330 def /hnom 22.85 def /xmin 0.264 def /xmax 0.660 def
    /resolve_strictspec render
    xdim 1 array astore
    end
} [0.660] isEqual

%
% resolve_strictspec: user xdim overrides xnom*mag
%
{
    10 dict begin
    /strictspec true def /propspec false def /loosespec false def /mag 1.0 def /xdim 0.500 def /hdim -1.0 def
    /xnom 0.330 def /hnom 22.85 def /xmin 0.264 def /xmax 0.660 def
    /resolve_strictspec render
    xdim 1 array astore
    end
} [0.500] isEqual

%
% resolve_strictspec: resolves hdim from hnom * mag
%
{
    10 dict begin
    /strictspec true def /propspec false def /loosespec false def /mag 1.5 def /xdim -1.0 def /hdim -1.0 def
    /xnom 0.330 def /hnom 22.85 def /xmin 0.264 def /xmax 0.660 def
    /resolve_strictspec render
    hdim 1 array astore
    end
} [34.275] isEqual

%
% resolve_strictspec: hdim stays -1 when hnom is -1
%
{
    10 dict begin
    /strictspec true def /propspec false def /loosespec false def /mag 1.0 def /xdim -1.0 def /hdim -1.0 def
    /xnom 0.330 def /hnom -1.0 def /xmin 0.264 def /xmax 0.660 def
    /resolve_strictspec render
    hdim 1 array astore
    end
} [-1.0] isEqual

%
% resolve_strictspec: mag exclusive with xdim
%
{
    10 dict begin
    /strictspec true def /propspec false def /loosespec false def /mag 2.0 def /xdim 0.500 def /hdim -1.0 def
    /xnom 0.330 def /hnom 22.85 def /xmin 0.264 def /xmax 0.660 def
    { /resolve_strictspec render } stopped { end stop } if
    end
} /bwipp.renderMagExclusive isError

%
% resolve_strictspec: mag exclusive with hdim
%
{
    10 dict begin
    /strictspec true def /propspec false def /loosespec false def /mag 2.0 def /xdim -1.0 def /hdim 30.0 def
    /xnom 0.330 def /hnom 22.85 def /xmin 0.264 def /xmax 0.660 def
    { /resolve_strictspec render } stopped { end stop } if
    end
} /bwipp.renderMagExclusive isError

%
% resolve_strictspec: missing xnom without xdim
%
{
    10 dict begin
    /strictspec true def /propspec false def /loosespec false def /mag 1.0 def /xdim -1.0 def /hdim -1.0 def
    /xnom -1.0 def /hnom -1.0 def /xmin -1.0 def /xmax -1.0 def
    { /resolve_strictspec render } stopped { end stop } if
    end
} /bwipp.renderNeedXnom isError

%
% resolve_strictspec: xdim below xmin
%
{
    10 dict begin
    /strictspec true def /propspec false def /loosespec false def /mag 0.5 def /xdim -1.0 def /hdim -1.0 def
    /xnom 0.330 def /hnom 22.85 def /xmin 0.264 def /xmax 0.660 def
    { /resolve_strictspec render } stopped { end stop } if
    end
} /bwipp.renderXdimTooSmall isError

%
% resolve_strictspec: xdim above xmax
%
{
    10 dict begin
    /strictspec true def /propspec false def /loosespec false def /mag 3.0 def /xdim -1.0 def /hdim -1.0 def
    /xnom 0.330 def /hnom 22.85 def /xmin 0.264 def /xmax 0.660 def
    { /resolve_strictspec render } stopped { end stop } if
    end
} /bwipp.renderXdimTooLarge isError

%
% resolve_height: propspec with sentinel height derives pixel-locked
%
{
    7 dict begin
    /propspec true def /strictspec false def /height -1.0 def
    /hnom 22.85 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [0.9583] isEqual

%
% resolve_height: strictspec derives height (not pixel-locked)
%
{
    7 dict begin
    /propspec false def /strictspec true def /height -1.0 def
    /hnom 22.85 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [0.9617] isEqual

%
% resolve_height: propspec with user height applies as multiplier
%
{
    7 dict begin
    /propspec true def /strictspec false def /height 0.5 def
    /hnom 22.85 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [0.4792] isEqual

%
% resolve_height: propspec height=1.0 is identity
%
{
    7 dict begin
    /propspec true def /strictspec false def /height 1.0 def
    /hnom 22.85 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [0.9583] isEqual

%
% resolve_height: propspec height=1.5 scales up
%
{
    7 dict begin
    /propspec true def /strictspec false def /height 1.5 def
    /hnom 22.85 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [1.4375] isEqual

%
% resolve_height: returns sentinel when hnom is -1
%
{
    7 dict begin
    /propspec true def /strictspec false def /height -1.0 def
    /hnom -1.0 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [-1.0] isEqual

%
% resolve_height: returns sentinel when neither propspec nor strictspec
%
{
    7 dict begin
    /propspec false def /strictspec false def /height -1.0 def
    /hnom 22.85 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [-1.0] isEqual

%
% resolve_height: missing xnom with propspec and hnom
%
{
    7 dict begin
    /propspec true def /strictspec false def /height -1.0 def
    /hnom 22.85 def /xnom -1.0 def /modunit 1 def
    { /resolve_height render } stopped { end stop } if
    end
} /bwipp.renderHnomNeedXnom isError

%
% resolve_height: propspec modunit=2, pixel-locked
%
{
    7 dict begin
    /propspec true def /strictspec false def /height -1.0 def
    /hnom 22.85 def /xnom 0.330 def /modunit 2 def
    /resolve_height render
    1 array astore
    end
} [1.9167] isEqual

%
% resolve_height: strictspec overrides user-set height
%
{
    7 dict begin
    /propspec false def /strictspec true def /height 0.5 def
    /hnom 22.85 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [0.9617] isEqual

%
% resolve_height: strictspec without hnom returns current height
%
{
    7 dict begin
    /propspec false def /strictspec true def /height 0.5 def
    /hnom -1.0 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [0.5] isEqual

%
% resolve_height: strictspec with sentinel height and no hnom returns sentinel
%
{
    7 dict begin
    /propspec false def /strictspec true def /height -1.0 def
    /hnom -1.0 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [-1.0] isEqual

%
% resolve_height: strictspec with explicit hdim derives from hdim/xdim
%
{
    9 dict begin
    /propspec false def /strictspec true def /height -1.0 def
    /hdim 20.0 def /xdim 0.330 def
    /hnom 22.85 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [0.8418] isEqual

%
% resolve_height: strictspec with hdim from hnom*mag equals hnom/xnom derivation
%
{
    9 dict begin
    /propspec false def /strictspec true def /height -1.0 def
    /hdim 22.85 def /xdim 0.330 def
    /hnom 22.85 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [0.9617] isEqual

%
% resolve_height: strictspec with hdim and modunit=2
%
{
    9 dict begin
    /propspec false def /strictspec true def /height -1.0 def
    /hdim 20.0 def /xdim 0.330 def
    /hnom -1.0 def /xnom 0.330 def /modunit 2 def
    /resolve_height render
    1 array astore
    end
} [1.6835] isEqual

%
% resolve_height: strictspec without hdim still uses hnom/xnom
%
{
    7 dict begin
    /propspec false def /strictspec true def /height -1.0 def
    /hnom 22.85 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [0.9617] isEqual

%
% resolve_height: hdim sentinel (-1) falls through to hnom/xnom derivation
%
{
    9 dict begin
    /propspec false def /strictspec true def /height -1.0 def
    /hdim -1.0 def /xdim 0.330 def
    /hnom 22.85 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [0.9617] isEqual

%
% resolve_height: propspec ignores hdim (propspec uses hnom/xnom ratio)
%
{
    9 dict begin
    /propspec true def /strictspec false def /height -1.0 def
    /hdim 20.0 def /xdim 0.330 def
    /hnom 22.85 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [0.9583] isEqual

%
% resolve_strictspec: loosespec disables strictspec when xnom missing
%
{
    9 dict begin
    /strictspec false def /propspec false def /loosespec true def /mag 1.0 def /xdim -1.0 def
    /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def /modunit 1 def
    /resolve_strictspec render
    strictspec 1 array astore
    end
} [false] isEqual

%
% resolve_strictspec: loosespec suppresses bounds error, preserves bounds for gridfit
%
{
    9 dict begin
    /strictspec false def /propspec false def /loosespec true def /mag 1.0 def /xdim 0.200 def
    /xnom -1.0 def /xmin 0.264 def /xmax 0.660 def /modunit 1 def
    /resolve_strictspec render
    strictspec xdim xmin xmax 4 array astore
    end
} [true 0.200 0.264 0.660] isEqual

%
% resolve_strictspec: loosespec preserves bounds when xdim is in-spec
%
{
    9 dict begin
    /strictspec false def /propspec false def /loosespec true def /mag 1.0 def /xdim 0.400 def
    /xnom -1.0 def /xmin 0.264 def /xmax 0.660 def /modunit 1 def
    /resolve_strictspec render
    xmin xmax 2 array astore
    end
} [0.264 0.660] isEqual

%
% resolve_strictspec: without loosespec, missing xnom errors
%
{
    9 dict begin
    /strictspec true def /propspec false def /loosespec false def /mag 1.0 def /xdim -1.0 def
    /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def /modunit 1 def
    { /resolve_strictspec render } stopped { end stop } if
    end
} /bwipp.renderNeedXnom isError

%
% resolve_strictspec: without loosespec, bounds violation errors
%
{
    9 dict begin
    /strictspec true def /propspec false def /loosespec false def /mag 1.0 def /xdim 0.200 def
    /xnom -1.0 def /xmin 0.264 def /xmax 0.660 def /modunit 1 def
    { /resolve_strictspec render } stopped { end stop } if
    end
} /bwipp.renderXdimTooSmall isError

%
% resolve_strictspec: loosespec with valid input is a no-op
%
{
    9 dict begin
    /strictspec false def /propspec false def /loosespec true def /mag 1.0 def /xdim -1.0 def
    /xnom 0.330 def /xmin 0.264 def /xmax 0.660 def /modunit 1 def
    /resolve_strictspec render
    strictspec xdim xmin xmax 4 array astore
    end
} [true 0.330 0.264 0.660] isEqual

%
% resolve_strictspec: loosespec defaults to false from global_ctx
%
{
    10 dict begin
    /strictspec true def /propspec false def /loosespec false def /mag 1.0 def /xdim -1.0 def
    /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def /modunit 1 def
    { /resolve_strictspec render } stopped { end stop } if
    end
} /bwipp.renderNeedXnom isError

%
% resolve_strictspec: loosespec implies strictspec
%
{
    9 dict begin
    /strictspec false def /propspec false def /loosespec true def /mag 1.0 def /xdim -1.0 def
    /xnom 0.330 def /xmin 0.264 def /xmax 0.660 def /modunit 1 def
    /resolve_strictspec render
    strictspec xdim 2 array astore
    end
} [true 0.330] isEqual

%
% resolve_strictspec: loosespec implies strictspec, but no xnom disables it
%
{
    9 dict begin
    /strictspec false def /propspec false def /loosespec true def /mag 1.0 def /xdim -1.0 def
    /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def /modunit 1 def
    /resolve_strictspec render
    strictspec 1 array astore
    end
} [false] isEqual

%
% global_encoder_defaults: loosespec from global_ctx implication deferred to resolve_strictspec
%
{
    8 dict begin
    /propspec false def /loosespec false def /strictspec false def
    /uk.co.terryburton.bwipp.global_ctx << /loosespec true >> def
    /global_encoder_defaults render
    strictspec loosespec 2 array astore
    end
} [false true] isEqual

%
% global_encoder_defaults: strictspec from global_ctx
%
{
    8 dict begin
    /propspec false def /loosespec false def /strictspec false def
    /uk.co.terryburton.bwipp.global_ctx << /strictspec true >> def
    /global_encoder_defaults render
    strictspec loosespec 2 array astore
    end
} [true false] isEqual

%
% global_encoder_defaults: propspec from global_ctx
%
{
    8 dict begin
    /propspec false def /loosespec false def /strictspec false def
    /uk.co.terryburton.bwipp.global_ctx << /propspec true >> def
    /global_encoder_defaults render
    propspec strictspec 2 array astore
    end
} [true false] isEqual

%
% global_encoder_defaults: user option overrides (not downgraded by global_ctx)
%
{
    8 dict begin
    /propspec true def /loosespec false def /strictspec true def
    /uk.co.terryburton.bwipp.global_ctx << >> def
    /global_encoder_defaults render
    strictspec propspec 2 array astore
    end
} [true true] isEqual

%
% global_encoder_defaults: suppressed by _dontdraw (sub-encoder)
%
{
    8 dict begin
    /propspec false def /loosespec false def /strictspec false def
    /uk.co.terryburton.bwipp.global_ctx << /loosespec true /propspec true >> def
    /uk.co.terryburton.bwipp._dontdraw true def
    /global_encoder_defaults render
    strictspec propspec loosespec 3 array astore
    end
} [false false false] isEqual

%
% global_encoder_defaults: not suppressed without _dontdraw
%
{
    8 dict begin
    /propspec false def /loosespec false def /strictspec false def
    /uk.co.terryburton.bwipp.global_ctx << /loosespec true /propspec true >> def
    /global_encoder_defaults render
    strictspec propspec loosespec 3 array astore
    end
} [false true true] isEqual

%
% Spec mode mutex: strictspec + loosespec errors
%
{
    8 dict begin
    /strictspec true def /loosespec true def /propspec false def
    /mag 1.0 def /xdim -1.0 def /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def
    { /resolve_strictspec render } stopped { end stop } if
    end
} /bwipp.renderSpecModeMutex isError

%
% Spec mode mutex: strictspec + propspec errors
%
{
    8 dict begin
    /strictspec true def /loosespec false def /propspec true def
    /mag 1.0 def /xdim -1.0 def /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def
    { /resolve_strictspec render } stopped { end stop } if
    end
} /bwipp.renderSpecModeMutex isError

%
% Spec mode mutex: loosespec + propspec errors
%
{
    8 dict begin
    /strictspec false def /loosespec true def /propspec true def
    /mag 1.0 def /xdim -1.0 def /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def
    { /resolve_strictspec render } stopped { end stop } if
    end
} /bwipp.renderSpecModeMutex isError

%
% Orphaned option validation: xdim without spec mode errors
%
{
    8 dict begin
    /strictspec false def /propspec false def /loosespec false def
    /mag 1.0 def /xdim 0.500 def /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def
    { /resolve_strictspec render } stopped { end stop } if
    end
} /bwipp.renderOrphanedXdim isError

%
% Orphaned option validation: hdim without spec mode errors
%
{
    9 dict begin
    /strictspec false def /propspec false def /loosespec false def
    /mag 1.0 def /xdim -1.0 def /hdim 10.0 def /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def
    { /resolve_strictspec render } stopped { end stop } if
    end
} /bwipp.renderOrphanedHdim isError

%
% Orphaned option validation: mag without spec mode errors
%
{
    8 dict begin
    /strictspec false def /propspec false def /loosespec false def
    /mag 2.0 def /xdim -1.0 def /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def
    { /resolve_strictspec render } stopped { end stop } if
    end
} /bwipp.renderOrphanedMag isError

%
% Orphaned option validation: xdim with propspec errors (propspec does not use xdim)
%
{
    8 dict begin
    /strictspec false def /propspec true def /loosespec false def
    /mag 1.0 def /xdim 0.500 def /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def
    { /resolve_strictspec render } stopped { end stop } if
    end
} /bwipp.renderOrphanedXdim isError

%
% Orphaned option validation: mag with propspec errors
%
{
    8 dict begin
    /strictspec false def /propspec true def /loosespec false def
    /mag 2.0 def /xdim -1.0 def /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def
    { /resolve_strictspec render } stopped { end stop } if
    end
} /bwipp.renderOrphanedMag isError

%
% Orphaned option validation: ast (non-default) without spec mode errors
%
{
    9 dict begin
    /strictspec false def /propspec false def /loosespec false def
    /mag 1.0 def /xdim -1.0 def /ast (gs1.sst1) def /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def
    { /resolve_strictspec render } stopped { end stop } if
    end
} /bwipp.renderOrphanedAST isError

%
% Orphaned option validation: ast=default without spec mode is OK
%
{
    9 dict begin
    /strictspec false def /propspec false def /loosespec false def
    /mag 1.0 def /xdim -1.0 def /ast (default) def /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def
    /resolve_strictspec render
    true 1 array astore
    end
} [true] isEqual

%
% Orphaned option validation: xdim with strictspec is OK
%
{
    8 dict begin
    /strictspec true def /loosespec false def /propspec false def
    /mag 1.0 def /xdim 0.500 def /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def
    /resolve_strictspec render
    xdim 1 array astore
    end
} [0.500] isEqual

%
% Orphaned option validation: xdim with loosespec is OK
%
{
    8 dict begin
    /strictspec false def /loosespec true def /propspec false def
    /mag 1.0 def /xdim 0.500 def /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def
    /resolve_strictspec render
    xdim 1 array astore
    end
} [0.500] isEqual

%
% Orphaned option validation: ast with propspec is OK
%
{
    9 dict begin
    /strictspec false def /loosespec false def /propspec true def
    /mag 1.0 def /xdim -1.0 def /ast (gs1.sst1) def /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def
    /resolve_strictspec render
    true 1 array astore
    end
} [true] isEqual

%
% Orphaned option validation: default sentinels without spec mode is OK
%
{
    8 dict begin
    /strictspec false def /propspec false def /loosespec false def
    /mag 1.0 def /xdim -1.0 def /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def
    /resolve_strictspec render
    true 1 array astore
    end
} [true] isEqual

%
% Orphaned option validation: suppressed by _dontdraw (sub-encoder)
%
{
    9 dict begin
    /strictspec false def /propspec false def /loosespec false def
    /mag 1.0 def /xdim 0.500 def /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def
    /uk.co.terryburton.bwipp._dontdraw true def
    /resolve_strictspec render
    true 1 array astore
    end
} [true] isEqual
