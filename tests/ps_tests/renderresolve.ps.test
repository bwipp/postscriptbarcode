% Barcode Writer in Pure PostScript
% https://bwipp.terryburton.co.uk
%
% vim: set sw=4 sts=4 et:
%
% Copyright (c) 2004-2026 Terry Burton
%

/render dup /uk.co.terryburton.bwipp findresource cvx def
/raiseerror dup /uk.co.terryburton.bwipp findresource cvx def

%
% resolve_physspec: physspec=false is a no-op
%
{
    8 dict begin
    /physspec false def /mag 1.0 def /xdim -1.0 def /hdim -1.0 def
    /xnom 0.330 def /hnom 22.85 def /xmin 0.264 def /xmax 0.660 def
    /resolve_physspec render
    xdim 1 array astore
    end
} [-1.0] isEqual

%
% resolve_physspec: resolves xdim from xnom * mag
%
{
    8 dict begin
    /physspec true def /mag 1.0 def /xdim -1.0 def /hdim -1.0 def
    /xnom 0.330 def /hnom 22.85 def /xmin 0.264 def /xmax 0.660 def
    /resolve_physspec render
    xdim 1 array astore
    end
} [0.330] isEqual

%
% resolve_physspec: resolves xdim with mag=2.0
%
{
    8 dict begin
    /physspec true def /mag 2.0 def /xdim -1.0 def /hdim -1.0 def
    /xnom 0.330 def /hnom 22.85 def /xmin 0.264 def /xmax 0.660 def
    /resolve_physspec render
    xdim 1 array astore
    end
} [0.660] isEqual

%
% resolve_physspec: user xdim overrides xnom*mag
%
{
    8 dict begin
    /physspec true def /mag 1.0 def /xdim 0.500 def /hdim -1.0 def
    /xnom 0.330 def /hnom 22.85 def /xmin 0.264 def /xmax 0.660 def
    /resolve_physspec render
    xdim 1 array astore
    end
} [0.500] isEqual

%
% resolve_physspec: resolves hdim from hnom * mag
%
{
    8 dict begin
    /physspec true def /mag 1.5 def /xdim -1.0 def /hdim -1.0 def
    /xnom 0.330 def /hnom 22.85 def /xmin 0.264 def /xmax 0.660 def
    /resolve_physspec render
    hdim 1 array astore
    end
} [34.275] isEqual

%
% resolve_physspec: hdim stays -1 when hnom is -1
%
{
    8 dict begin
    /physspec true def /mag 1.0 def /xdim -1.0 def /hdim -1.0 def
    /xnom 0.330 def /hnom -1.0 def /xmin 0.264 def /xmax 0.660 def
    /resolve_physspec render
    hdim 1 array astore
    end
} [-1.0] isEqual

%
% resolve_physspec: mag exclusive with xdim
%
{
    8 dict begin
    /physspec true def /mag 2.0 def /xdim 0.500 def /hdim -1.0 def
    /xnom 0.330 def /hnom 22.85 def /xmin 0.264 def /xmax 0.660 def
    { /resolve_physspec render } stopped { end stop } if
    end
} /bwipp.renderMagExclusive isError

%
% resolve_physspec: mag exclusive with hdim
%
{
    8 dict begin
    /physspec true def /mag 2.0 def /xdim -1.0 def /hdim 30.0 def
    /xnom 0.330 def /hnom 22.85 def /xmin 0.264 def /xmax 0.660 def
    { /resolve_physspec render } stopped { end stop } if
    end
} /bwipp.renderMagExclusive isError

%
% resolve_physspec: missing xnom without xdim
%
{
    8 dict begin
    /physspec true def /mag 1.0 def /xdim -1.0 def /hdim -1.0 def
    /xnom -1.0 def /hnom -1.0 def /xmin -1.0 def /xmax -1.0 def
    { /resolve_physspec render } stopped { end stop } if
    end
} /bwipp.renderNeedXnom isError

%
% resolve_physspec: xdim below xmin
%
{
    8 dict begin
    /physspec true def /mag 0.5 def /xdim -1.0 def /hdim -1.0 def
    /xnom 0.330 def /hnom 22.85 def /xmin 0.264 def /xmax 0.660 def
    { /resolve_physspec render } stopped { end stop } if
    end
} /bwipp.renderXdimTooSmall isError

%
% resolve_physspec: xdim above xmax
%
{
    8 dict begin
    /physspec true def /mag 3.0 def /xdim -1.0 def /hdim -1.0 def
    /xnom 0.330 def /hnom 22.85 def /xmin 0.264 def /xmax 0.660 def
    { /resolve_physspec render } stopped { end stop } if
    end
} /bwipp.renderXdimTooLarge isError

%
% resolve_height: propspec with sentinel height derives pixel-locked
%
{
    7 dict begin
    /propspec true def /physspec false def /height -1.0 def
    /hnom 22.85 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [0.9583] isEqual

%
% resolve_height: physspec derives height (not pixel-locked)
%
{
    7 dict begin
    /propspec false def /physspec true def /height -1.0 def
    /hnom 22.85 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [0.9617] isEqual

%
% resolve_height: propspec with user-set height returns user height
%
{
    7 dict begin
    /propspec true def /physspec false def /height 0.5 def
    /hnom 22.85 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [0.5] isEqual

%
% resolve_height: returns sentinel when hnom is -1
%
{
    7 dict begin
    /propspec true def /physspec false def /height -1.0 def
    /hnom -1.0 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [-1.0] isEqual

%
% resolve_height: returns sentinel when neither propspec nor physspec
%
{
    7 dict begin
    /propspec false def /physspec false def /height -1.0 def
    /hnom 22.85 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [-1.0] isEqual

%
% resolve_height: missing xnom with propspec and hnom
%
{
    7 dict begin
    /propspec true def /physspec false def /height -1.0 def
    /hnom 22.85 def /xnom -1.0 def /modunit 1 def
    { /resolve_height render } stopped { end stop } if
    end
} /bwipp.renderHnomNeedXnom isError

%
% resolve_height: propspec modunit=2, pixel-locked
%
{
    7 dict begin
    /propspec true def /physspec false def /height -1.0 def
    /hnom 22.85 def /xnom 0.330 def /modunit 2 def
    /resolve_height render
    1 array astore
    end
} [1.9167] isEqual

%
% resolve_height: physspec overrides user-set height
%
{
    7 dict begin
    /propspec false def /physspec true def /height 0.5 def
    /hnom 22.85 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [0.9617] isEqual

%
% resolve_height: physspec without hnom returns current height
%
{
    7 dict begin
    /propspec false def /physspec true def /height 0.5 def
    /hnom -1.0 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [0.5] isEqual

%
% resolve_height: physspec with sentinel height and no hnom returns sentinel
%
{
    7 dict begin
    /propspec false def /physspec true def /height -1.0 def
    /hnom -1.0 def /xnom 0.330 def /modunit 1 def
    /resolve_height render
    1 array astore
    end
} [-1.0] isEqual

%
% resolve_physspec: bestfit disables physspec when xnom missing
%
{
    8 dict begin
    /physspec true def /bestfit true def /mag 1.0 def /xdim -1.0 def
    /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def /modunit 1 def
    /resolve_physspec render
    physspec 1 array astore
    end
} [false] isEqual

%
% resolve_physspec: bestfit suppresses bounds error, preserves bounds for gridfit
%
{
    8 dict begin
    /physspec true def /bestfit true def /mag 1.0 def /xdim 0.200 def
    /xnom -1.0 def /xmin 0.264 def /xmax 0.660 def /modunit 1 def
    /resolve_physspec render
    physspec xdim xmin xmax 4 array astore
    end
} [true 0.200 0.264 0.660] isEqual

%
% resolve_physspec: bestfit preserves bounds when xdim is in-spec
%
{
    8 dict begin
    /physspec true def /bestfit true def /mag 1.0 def /xdim 0.400 def
    /xnom -1.0 def /xmin 0.264 def /xmax 0.660 def /modunit 1 def
    /resolve_physspec render
    xmin xmax 2 array astore
    end
} [0.264 0.660] isEqual

%
% resolve_physspec: without bestfit, missing xnom errors
%
{
    8 dict begin
    /physspec true def /bestfit false def /mag 1.0 def /xdim -1.0 def
    /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def /modunit 1 def
    { /resolve_physspec render } stopped { end stop } if
    end
} /bwipp.renderNeedXnom isError

%
% resolve_physspec: without bestfit, bounds violation errors
%
{
    8 dict begin
    /physspec true def /bestfit false def /mag 1.0 def /xdim 0.200 def
    /xnom -1.0 def /xmin 0.264 def /xmax 0.660 def /modunit 1 def
    { /resolve_physspec render } stopped { end stop } if
    end
} /bwipp.renderXdimTooSmall isError

%
% resolve_physspec: bestfit with valid input is a no-op
%
{
    8 dict begin
    /physspec true def /bestfit true def /mag 1.0 def /xdim -1.0 def
    /xnom 0.330 def /xmin 0.264 def /xmax 0.660 def /modunit 1 def
    /resolve_physspec render
    physspec xdim xmin xmax 4 array astore
    end
} [true 0.330 0.264 0.660] isEqual

%
% resolve_physspec: bestfit defaults to false from global_ctx
%
{
    8 dict begin
    /physspec true def /mag 1.0 def /xdim -1.0 def
    /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def /modunit 1 def
    { /resolve_physspec render } stopped { end stop } if
    end
} /bwipp.renderNeedXnom isError

%
% resolve_physspec: bestfit implies physspec
%
{
    8 dict begin
    /physspec false def /bestfit true def /mag 1.0 def /xdim -1.0 def
    /xnom 0.330 def /xmin 0.264 def /xmax 0.660 def /modunit 1 def
    /resolve_physspec render
    physspec xdim 2 array astore
    end
} [true 0.330] isEqual

%
% resolve_physspec: bestfit implies physspec, but no xnom disables it
%
{
    8 dict begin
    /physspec false def /bestfit true def /mag 1.0 def /xdim -1.0 def
    /xnom -1.0 def /xmin -1.0 def /xmax -1.0 def /modunit 1 def
    /resolve_physspec render
    physspec 1 array astore
    end
} [false] isEqual

%
% global_encoder_defaults: bestfit from global_ctx implies physspec
%
{
    8 dict begin
    /propspec false def /bestfit false def /physspec false def
    /uk.co.terryburton.bwipp.global_ctx << /bestfit true >> def
    /global_encoder_defaults render
    physspec bestfit 2 array astore
    end
} [true true] isEqual

%
% global_encoder_defaults: physspec from global_ctx
%
{
    8 dict begin
    /propspec false def /bestfit false def /physspec false def
    /uk.co.terryburton.bwipp.global_ctx << /physspec true >> def
    /global_encoder_defaults render
    physspec bestfit 2 array astore
    end
} [true false] isEqual

%
% global_encoder_defaults: propspec from global_ctx
%
{
    8 dict begin
    /propspec false def /bestfit false def /physspec false def
    /uk.co.terryburton.bwipp.global_ctx << /propspec true >> def
    /global_encoder_defaults render
    propspec physspec 2 array astore
    end
} [true false] isEqual

%
% global_encoder_defaults: user option overrides (not downgraded by global_ctx)
%
{
    8 dict begin
    /propspec true def /bestfit false def /physspec true def
    /uk.co.terryburton.bwipp.global_ctx << >> def
    /global_encoder_defaults render
    physspec propspec 2 array astore
    end
} [true true] isEqual

%
% global_encoder_defaults: suppressed by _dontdraw (sub-encoder)
%
{
    8 dict begin
    /propspec false def /bestfit false def /physspec false def
    /uk.co.terryburton.bwipp.global_ctx << /bestfit true /propspec true >> def
    /uk.co.terryburton.bwipp._dontdraw true def
    /global_encoder_defaults render
    physspec propspec bestfit 3 array astore
    end
} [false false false] isEqual

%
% global_encoder_defaults: not suppressed without _dontdraw
%
{
    8 dict begin
    /propspec false def /bestfit false def /physspec false def
    /uk.co.terryburton.bwipp.global_ctx << /bestfit true /propspec true >> def
    /global_encoder_defaults render
    physspec propspec bestfit 3 array astore
    end
} [true true true] isEqual
