% Barcode Writer in Pure PostScript
% https://bwipp.terryburton.co.uk
%
% vim: set sw=4 sts=4 et:
%
% Copyright (c) 2004-2026 Terry Burton
%

/processoptions dup /uk.co.terryburton.bwipp findresource cvx def
/render dup /uk.co.terryburton.bwipp findresource cvx def

/uk.co.terryburton.bwipp.global_ctx <<
    /named_colors <<
        (_testsep) [
            [ /Separation (Test Separation) /DeviceCMYK { dup 0.49 mul exch dup 0 mul exch dup 0.03 mul exch 0 mul } ]  1.0
        ]
    >>
>> def

% Build a text dict with defaults, applying overrides via a procedure
/mkdict {
    << () () (subspace) () (split) () (linegaps) 1.2
       (color) (unset) (xalign) (left) (yalign) (above)
       (direction) (forward) (font) (Courier) (size) 10.0
       (xoffset) 0.0 (yoffset) 0.0 (gaps) 0.0 >>
} def

% inject: copy empty-key value into (content) key, ensure (txt) exists
/inject { dup dup () get (content) exch put dup (txt) known not { dup (txt) [] put } if } def

% ok: { override-proc } grp ok_grp
/ok_grp {
    /ok_grp.grp exch def
    { 50 dict begin 100 100 0 mkdict 0 exec inject /rendertext render end }
    dup 5 ok_grp.grp put
    dup 3 -1 roll 7 exch put
    true isEqual
} def

% er: { override-proc } /errorname grp er_grp
% rendertext returns errorname errorstring false on error; pop pop leaves errorname
/er_grp {
    /er_grp.grp exch def
    exch
    { 50 dict begin 100 100 0 mkdict 0 exec inject /rendertext render pop pop end }
    dup 5 er_grp.grp put
    dup 3 -1 roll 7 exch put
    exch isEqual
} def

/ok_tmpl { 1 ok_grp } def
/er_tmpl { 1 er_grp } def


%
% Empty content (no-op)
%
{ } ok_tmpl


%
% txt array (encoder-positioned text, fast path)
%
{ dup (xalign) (unset) put dup (yalign) (unset) put dup (txt) [ [ (X) 0 0 (Courier) 10 ] ] put } ok_tmpl

{ dup (xalign) (unset) put dup (yalign) (unset) put dup (txt) [ [ (X) 0 0 (Courier)  0 ] ] put } /bwipp.fontTooSmall er_tmpl
{ dup (xalign) (unset) put dup (yalign) (unset) put dup (txt) [ [ (X) 0 0 (Courier) -1 ] ] put } /bwipp.fontTooSmall er_tmpl


%
% content (alttext equivalent)
%
{ dup () (TEST) put } ok_tmpl


%
% font size
%
{ dup () (TEST) put dup (font) (Helvetica) put } ok_tmpl
{ dup () (TEST) put dup (font) (Times-Roman) put } ok_tmpl
{ dup () (TEST) put dup (size) 8.0 put } ok_tmpl
{ dup () (TEST) put dup (size) 14.0 put } ok_tmpl


%
% split subspace
%
{ dup () (A|B) put dup (split) (|) put } ok_tmpl
{ dup () (A_B) put dup (subspace) (_) put } ok_tmpl

{ dup () (A|B) put dup (split) (||) put } /bwipp.textsplitBad er_tmpl
{ dup () (A_B) put dup (subspace) (__) put } /bwipp.textsubspaceBad er_tmpl


%
% color
%
{ dup () (TEST) put dup (color) (FF0000) put } ok_tmpl
{ dup () (TEST) put dup (color) (00FF0000) put } ok_tmpl
{ dup () (TEST) put dup (color) (_testsep) put } ok_tmpl


%
% direction
%
{ dup () (TEST) put dup (direction) (forward) put } ok_tmpl
{ dup () (TEST) put dup (direction) (backward) put } ok_tmpl
{ dup () (TEST) put dup (direction) (upward) put } ok_tmpl
{ dup () (TEST) put dup (direction) (downward) put } ok_tmpl


%
% offsets
%
{ dup () (TEST) put dup (xoffset)  5.0 put } ok_tmpl
{ dup () (TEST) put dup (xoffset) -5.0 put } ok_tmpl
{ dup () (TEST) put dup (yoffset)  5.0 put } ok_tmpl
{ dup () (TEST) put dup (yoffset) -5.0 put } ok_tmpl


%
% gaps linegaps
%
{ dup () (TEST) put dup (gaps) 1.0 put } ok_tmpl
{ dup () (TEST) put dup (linegaps) 2.0 put } ok_tmpl


%
% xalign
%
{ dup () (TEST) put dup (xalign) (left) put } ok_tmpl
{ dup () (TEST) put dup (xalign) (center) put } ok_tmpl
{ dup () (TEST) put dup (xalign) (right) put } ok_tmpl
{ dup () (TEST) put dup (xalign) (offleft) put } ok_tmpl
{ dup () (TEST) put dup (xalign) (offright) put } ok_tmpl

{ dup () (TEST) put dup (xalign) (justify) put dup (direction) (forward) put } ok_tmpl
{ dup () (TEST) put dup (xalign) (justify) put dup (direction) (backward) put } ok_tmpl
{ dup () (A) put dup (xalign) (justify) put dup (direction) (forward) put } ok_tmpl

{ dup () (TEST) put dup (xalign) (justify) put dup (direction) (upward) put } /bwipp.textxjustify er_tmpl
{ dup () (TEST) put dup (xalign) (justify) put dup (direction) (downward) put } /bwipp.textxjustify er_tmpl


%
% yalign
%
{ dup () (TEST) put dup (yalign) (above) put } ok_tmpl
{ dup () (TEST) put dup (yalign) (below) put } ok_tmpl
{ dup () (TEST) put dup (yalign) (top) put } ok_tmpl
{ dup () (TEST) put dup (yalign) (bottom) put } ok_tmpl
{ dup () (TEST) put dup (yalign) (center) put } ok_tmpl

{ dup () (TEST) put dup (yalign) (justify) put dup (direction) (upward) put } ok_tmpl
{ dup () (TEST) put dup (yalign) (justify) put dup (direction) (downward) put } ok_tmpl
{ dup () (A) put dup (yalign) (justify) put dup (direction) (upward) put } ok_tmpl

{ dup () (TEST) put dup (yalign) (justify) put dup (direction) (forward) put } /bwipp.textyjustify er_tmpl
{ dup () (TEST) put dup (yalign) (justify) put dup (direction) (backward) put } /bwipp.textyjustify er_tmpl


%
% text2 errors (old names)
%
{ dup () (A|B) put dup (split) (||) put } /bwipp.extratextsplitBad 2 er_grp
{ dup () (A_B) put dup (subspace) (__) put } /bwipp.extratextsubspaceBad 2 er_grp
{ dup () (TEST) put dup (xalign) (justify) put dup (direction) (upward) put } /bwipp.extratextxjustify 2 er_grp
{ dup () (TEST) put dup (yalign) (justify) put dup (direction) (forward) put } /bwipp.extratextyjustify 2 er_grp


%
% text3 (new group)
%
{ dup () (EXTRA) put } 3 ok_grp
{ dup () (EXTRA) put dup (font) (Helvetica) put } 3 ok_grp
{ dup () (EXTRA) put dup (xalign) (center) put dup (yalign) (below) put } 3 ok_grp

{ dup () (EXTRA) put dup (xalign) (justify) put dup (direction) (upward) put }
    /bwipp.text3xjustify 3 er_grp
{ dup () (EXTRA) put dup (yalign) (justify) put dup (direction) (forward) put }
    /bwipp.text3yjustify 3 er_grp
{ dup () (A|B) put dup (split) (||) put } /bwipp.text3splitBad 3 er_grp
{ dup () (A_B) put dup (subspace) (__) put } /bwipp.text3subspaceBad 3 er_grp


%
% unset alignment defaults (text1 slow path with txt extraction)
%
{ dup (xalign) (unset) put dup (yalign) (unset) put dup (txt) [ [ (A) 0 0 (Courier) 10 ] [ (B) 10 0 (Courier) 10 ] ] put } ok_tmpl


%
% /groupoptions returns the suffixes template
%
{
    /groupoptions render
    type /dicttype eq
} true isEqual


%
% /apply resolves aliases to canonical names
%
{
    50 dict begin
    /text1font (Courier) def
    /text1xalign (unset) def
    /text1 () def
    /text2font (Courier) def
    (textfont=Helvetica text1xalign=center alttext=HELLO extratextfont=Times) null /apply processoptions pop
    text1font text1xalign text1 text2font 4 array astore
    end
} [(Helvetica) (center) (HELLO) (Times)] isEqual


%
% Multiple text groups active simultaneously
%
{
    50 dict begin /pixx 100 def /pixy 100 def
    100 100 1 mkdict dup () (ONE) put inject /rendertext render
    100 100 3 mkdict dup () (TWO) put inject /rendertext render
    and
    end
} true isEqual
