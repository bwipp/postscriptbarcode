%

% GS1 General Specifications 22.0 (Jan 2022)


/gs1-128 dup /uk.co.terryburton.bwipp findresource cvx def

/eq_tmpl {
    exch { 0 (dontdraw) gs1-128 /sbs get } dup 3 -1 roll 0 exch put
    exch isEqual
} def


((01)09501101530003)  % GS1 General Specifications Figure 5.1-3. GS1-128 barcode, same
    [2 1 1 2 3 2 4 1 1 1 3 1 2 2 2 1 2 2 2 2 1 2 1 3 2 3 1 1 3 1 2 3 1 2 1 2 2 2 2 1 2 2 2 1 3 1 3 1 2 1 2 2 2 2 1 2 1 2 2 3 1 2 2 1 1 4 2 3 3 1 1 1 2]
    eq_tmpl

{  % Avoid extraneous CodeC switch (with immediate switch back to CodeA/B) by re-checking digit runlength >= 4 after enca/encb push
    ((90)111(91)2(92)3) (debugcws) gs1-128
} [105 102 90 11 100 17 102 25 17 18 102 25 18 19 40 106] debugIsEqual


%
% Error tests
%

{ ((01)09501101530003) (linkagea linkagec dontdraw) gs1-128 } /bwipp.gs1128badLinkage isError

{ 501 string (dontdraw) gs1-128 } /bwipp.gs1128inputTooLong isError

% physspec smoke test
{ 0 0 moveto (\(01\)09521234543213\(3103\)000123) (includetext physspec xdim=0.330) gs1-128 true } true isEqual

%
% AST bounds (default): xdim below xmin (0.170) fails
%
{ (\(01\)09521234543213) (dontdraw physspec xdim=0.100) gs1-128 } /bwipp.renderXdimTooSmall isError

%
% AST bounds (default): xdim above xmax (1.016) fails
%
{ (\(01\)09521234543213) (dontdraw physspec xdim=1.100) gs1-128 } /bwipp.renderXdimTooLarge isError

%
% AST bounds (gs1.sst2): tighter xmin (0.495) applied via wrapper AST
%
{ (\(01\)09521234543213) (dontdraw physspec ast=gs1.sst2 xdim=0.330) gs1-128 } /bwipp.renderXdimTooSmall isError

%
% propspec: height derived from sst2 AST hnom/xnom through wrapper
% hnom=31.75 xnom=0.495: round(31.75/0.495)=64, 64/72=0.8889
%
{
    (\(01\)09521234543213) (dontdraw propspec ast=gs1.sst2) gs1-128 /bhs get 0 get 1 array astore
} [0.8889] isEqual

%
% propspec without hnom (default AST): falls back to wrapper height default (0.5)
%
{
    (\(01\)09521234543213) (dontdraw propspec) gs1-128 /bhs get 0 get 1 array astore
} [0.5] isEqual

%
% physspec with sst2: xdim resolves from xnom (0.495)
%
{
    (\(01\)09521234543213) (dontdraw physspec ast=gs1.sst2) gs1-128 dup /physspec get exch /xdim get 2 array astore
} [true 0.495] isEqual

% propspec + user height with SST: user wins
{ (\(01\)09521234543213) (dontdraw propspec ast=gs1.sst2 height=0.3) gs1-128 /bhs get 0 get 1 array astore } [0.3] isEqual
