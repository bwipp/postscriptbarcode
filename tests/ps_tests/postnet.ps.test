/postnet dup /uk.co.terryburton.bwipp findresource cvx def

{ (01234) (dontdraw) postnet /bhs get
} [ 0.125 0.125 0.125 0.05 0.05 0.05 0.05 0.05 0.05 0.125 0.125 0.05 0.05 0.125 0.05 0.125 0.05 0.05 0.125 0.125 0.05 0.05 0.125 0.05 0.05 0.125 0.125 0.125 0.05 0.05 0.05 0.125 ] debugIsEqual


%
% Error tests
%

{ (1234) (dontdraw) postnet } /bwipp.postnetBadLength isError
{ (123456) (dontdraw) postnet } /bwipp.postnetBadLength isError
{ (0123A) (dontdraw) postnet } /bwipp.postnetBadCharacter isError
{ (012341) (validatecheck dontdraw) postnet } /bwipp.postnetBadCheckDigit isError


%
% Smoke test: propspec and physspec render without error
%
/ok_tmpl {
    { 0 0 moveto 0 0 postnet true } dup 3 -1 roll 4 exch put dup 3 -1 roll 3 exch put
    true isEqual
} def
(01234)  (includetext propspec)   ok_tmpl
(01234)  (includetext physspec xdim=0.330)   ok_tmpl
