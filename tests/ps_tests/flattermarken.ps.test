/flattermarken dup /uk.co.terryburton.bwipp findresource cvx def

{ (11099) (dontdraw) flattermarken /sbs get
} [ 0 0 1 8 0 0 1 8 0 9 0 0 0 8 1 0 0 8 1 0 ] debugIsEqual


%
% Error tests
%

{ (123A5) (dontdraw) flattermarken } /bwipp.flattermarkenBadCharacter isError

{ 501 string (dontdraw) flattermarken } /bwipp.flattermarkeninputTooLong isError


%
% Smoke test: physspec renders without error
%
/ok_tmpl {
    { 0 0 moveto 0 0 flattermarken true } dup 3 -1 roll 4 exch put dup 3 -1 roll 3 exch put
    true isEqual
} def
(11099)  (includetext physspec xdim=0.330)  ok_tmpl
