% Barcode Writer in Pure PostScript
% https://bwipp.terryburton.co.uk
%
% vim: set sw=4 sts=4 et:
%
% Copyright (c) 2004-2024 Terry Burton
%

% ISO/IEC 16388:2007


/code39 dup /uk.co.terryburton.bwipp findresource cvx def


% Input validation

{ () (dontdraw) code39
} /bwipp.code39emptyData isError

{ () (dontdraw validatecheck) code39
} /bwipp.code39emptyData isError

{ (,) (dontdraw) code39
} /bwipp.code39badCharacter isError

{ (Z1.) (dontdraw validatecheck) code39  % Check digit should be '-'
} /bwipp.code39badCheckDigit isError

{ 501 string (dontdraw) code39 } /bwipp.code39inputTooLong isError


% Examples

{ (0) (dontdraw) code39 /sbs get
} [ 1 3 1 1 3 1 3 1 1 1 1 1 1 3 3 1 3 1 1 1 1 3 1 1 3 1 3 1 1 1 ] debugIsEqual

{ (0) (dontdraw validatecheck) code39 /sbs get  % Degenerate case with check digit only still allowed
} [ 1 3 1 1 3 1 3 1 1 1 1 1 1 3 3 1 3 1 1 1 1 3 1 1 3 1 3 1 1 1 ] debugIsEqual

{ (1A) (dontdraw) code39 /sbs get  % Figure 1, same
} [ 1 3 1 1 3 1 3 1 1 1 3 1 1 3 1 1 1 1 3 1 3 1 1 1 1 3 1 1 3 1 1 3 1 1 3 1 3 1 1 1 ] debugIsEqual

{ (Z1-) (dontdraw validatecheck) code39 /sbs get
} [ 1 3 1 1 3 1 3 1 1 1 1 3 3 1 3 1 1 1 1 1 3 1 1 3 1 1 1 1 3 1 1 3 1 1 1 1 3 1 3 1 1 3 1 1 3 1 3 1 1 1 ] debugIsEqual

%
% Smoke test: propspec renders without error
%
/ok_tmpl {
    { 0 0 moveto 0 0 code39 true } dup 3 -1 roll 4 exch put dup 3 -1 roll 3 exch put
    true isEqual
} def
(THIS IS CODE 39)  (propspec)  ok_tmpl

% AST bounds: xdim below xmin fails
{ (THIS IS CODE 39) (dontdraw strictspec xdim=0.100) code39 } /bwipp.renderXdimTooSmall isError

%
% propspec: no-op when AST has no hnom
%
{ (TEST) (dontdraw propspec) code39 /bhs get 0 get 1 array astore } [1.0] isEqual
{ (TEST) (dontdraw propspec height=0.5) code39 /bhs get 0 get 1 array astore } [0.5] isEqual

%
% loosespec: falls back to default when no xnom available
%
/tmp uk.co.terryburton.bwipp.global_ctx def
/tmp uk.co.terryburton.bwipp.global_ctx def
/uk.co.terryburton.bwipp.global_ctx << /enabledebug true /enabledontdraw true /loosespec true >> def
{ (TEST) (dontdraw) code39 /strictspec get 1 array astore } [false] isEqual
{ (TEST) (dontdraw) code39 /bhs get 0 get 1 array astore } [1.0] isEqual
/uk.co.terryburton.bwipp.global_ctx tmp def
