% Barcode Writer in Pure PostScript
% https://bwipp.terryburton.co.uk
%
% vim: set sw=4 sts=4 et:
%
% Copyright (c) 2004-2024 Terry Burton
%

/ean8 dup /uk.co.terryburton.bwipp findresource cvx def

/eq_tmpl {
    exch { 0 (dontdraw) ean8 /sbs get } dup 3 -1 roll 0 exch put
    exch isEqual
} def

/er_tmpl {
    exch { 0 (dontdraw) ean8 /sbs get } dup 3 -1 roll 0 exch put
    exch isError
} def

/eq_tmpl_addon {
    exch { 0 (dontdraw permitaddon) ean8 /sbs get } dup 3 -1 roll 0 exch put
    exch isEqual
} def

/er_tmpl_addon {
    exch { 0 (dontdraw permitaddon) ean8 /sbs get } dup 3 -1 roll 0 exch put
    exch isError
} def


(02345673)       [1 1 1 3 2 1 1 2 1 2 2 1 4 1 1 1 1 3 2 1 1 1 1 1 1 2 3 1 1 1 1 4 1 3 1 2 1 4 1 1 1 1 1] eq_tmpl        % 8 digits
(0234567)        [1 1 1 3 2 1 1 2 1 2 2 1 4 1 1 1 1 3 2 1 1 1 1 1 1 2 3 1 1 1 1 4 1 3 1 2 1 4 1 1 1 1 1] eq_tmpl        % Omit checksum
(02345674)       /bwipp.ean8badCheckDigit                                                                er_tmpl        % Invalid checksum

(02345673 12345) [1 1 1 3 2 1 1 2 1 2 2 1 4 1 1 1 1 3 2 1 1 1 1 1 1 2 3 1 1 1 1 4 1 3 1 2 1 4 1 1 1 1 1                 % Add 5
                  12.0
                  1 1 2 1 2 2 2 1 1 2 1 2 2 1 1 1 1 4 1 1 1 1 1 3 2 1 1 1 2 3 1]                         eq_tmpl_addon

(02345673 12)    [1 1 1 3 2 1 1 2 1 2 2 1 4 1 1 1 1 3 2 1 1 1 1 1 1 2 3 1 1 1 1 4 1 3 1 2 1 4 1 1 1 1 1                 % Add 2
                  12.0
                  1 1 2 2 2 2 1 1 1 2 1 2 2]                                                             eq_tmpl_addon
(02345673 123)   /bwipp.ean8badAddOnLength                                                               er_tmpl_addon  % Add 3!

(A2345673)       /bwipp.ean8badCharacter                                                                 er_tmpl        % Bad character

(023456)         /bwipp.ean8badLength                                                                    er_tmpl        % Too short
(023456731)      /bwipp.ean8badLength                                                                    er_tmpl        % Too long

%
% Smoke test: strictspec renders without error
%
/ok_tmpl {
    { 0 0 moveto 0 0 ean8 true } dup 3 -1 roll 4 exch put dup 3 -1 roll 3 exch put
    true isEqual
} def
(95200002)  (strictspec)  ok_tmpl


% AST bounds: xdim below xmin fails
{ (95200002) (dontdraw strictspec xdim=0.200) ean8 } /bwipp.renderXdimTooSmall isError

%
% propspec: height derived from AST hnom/xnom, pixel-locked
% hnom=18.23 xnom=0.330: round(18.23/0.330)=55, 55/72=0.7639
%
{ (12345670) (dontdraw) ean8 /bhs get 0 get 1 array astore } [1.0] isEqual
{ (12345670) (dontdraw propspec) ean8 /bhs get 0 get 1 array astore } [0.7639] isEqual

% propspec + user height: multiplier on derived height
{ (12345670) (dontdraw propspec height=0.5) ean8 /bhs get 0 get 1 array astore } [0.3819] isEqual

% strictspec: xdim resolves from default AST xnom (0.330)
{ (12345670) (dontdraw strictspec) ean8 dup /strictspec get exch /xdim get 2 array astore } [true 0.330] isEqual


%
% addondescent: primary's add-on descent propagates to the add-on symbol
% and defaults to guarddescent. Inspect bbs[0] (primary left guard) and
% bbs[length-1] (last add-on bar).
%
/descents_tmpl {
    3 1 roll { 0 0 ean8 /bbs get dup 0 get exch dup length 1 sub get 2 array astore }
    dup 3 -1 roll 1 exch put dup 3 -1 roll 0 exch put
    exch isEqual
} def
(02345673 12345) (includetext permitaddon dontdraw)                               [-0.0694 -0.0694] descents_tmpl
(02345673 12345) (includetext permitaddon dontdraw addondescent=0)                [-0.0694  0.0   ] descents_tmpl
(02345673 12345) (includetext permitaddon dontdraw addondescent=8)                [-0.0694 -0.1111] descents_tmpl
(02345673 12345) (includetext permitaddon dontdraw guarddescent=8)                [-0.1111 -0.1111] descents_tmpl
(02345673 12345) (includetext permitaddon dontdraw guarddescent=8 addondescent=0) [-0.1111  0.0   ] descents_tmpl