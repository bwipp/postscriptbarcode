% Barcode Writer in Pure PostScript
% https://bwipp.terryburton.co.uk
%
% vim: set sw=4 sts=4 et:
%
% Copyright (c) 2004-2026 Terry Burton
%

/isbn dup /uk.co.terryburton.bwipp findresource cvx def

{ (978-1-56581-231-4) (dontdraw) isbn /sbs get
} [ 1 1 1 1 3 1 2 3 1 2 1 1 2 2 2 1 2 3 1 4 1 1 1 1 2 3 1 1 1 1 1 1 1 2 1 3 2 2 2 1 2 1 2 2 1 4 1 1 2 2 2 1 1 1 3 2 1 1 1 ] debugIsEqual


%
% Error tests
%

{ (978-1-5658-231) (dontdraw) isbn } /bwipp.isbnBadLength isError
{ (978-1-56581-231-4 123) (dontdraw) isbn } /bwipp.isbnBadAddOnLength isError
{ (123-1-56581-231-7) (dontdraw) isbn } /bwipp.isbn13badPrefix isError
{ (978-1--58121-31-7) (dontdraw) isbn } /bwipp.isbn13adjacentDashes isError
{ (978-1-565812314-7) (dontdraw) isbn } /bwipp.isbn13numDashesDigits isError
{ (978-1-56581-23A-7) (dontdraw) isbn } /bwipp.isbn13character15 isError
{ (978-1-56581-23147) (dontdraw) isbn } /bwipp.isbn13character16 isError
{ (978-1-56581-231-A) (dontdraw) isbn } /bwipp.isbn13character17 isError
{ (978-1-56581-231-0) (dontdraw) isbn } /bwipp.isbn13badCheckDigit isError
{ (A-56581-231-7) (dontdraw) isbn } /bwipp.isbn10FirstDigit isError
{ (1--6581-231-7) (dontdraw) isbn } /bwipp.isbn10adjacentDashes isError
{ (1-565812314-7) (dontdraw) isbn } /bwipp.isbn10numDashesDigits isError
{ (1-56581-23A-7) (dontdraw) isbn } /bwipp.isbn10character11 isError
{ (1-56581-231X7) (dontdraw) isbn } /bwipp.isbn10character12 isError
{ (1-56581-231-?) (dontdraw) isbn } /bwipp.isbn10character13 isError
{ (1-56581-231-0) (dontdraw) isbn } /bwipp.isbn10badCheckDigit isError

% AST bounds: xdim below xmin fails
{ (978-1-56581-231-4 90000) (dontdraw strictspec xdim=0.200) isbn } /bwipp.renderXdimTooSmall isError

%
% propspec: height derived through wrapper
%
{ (978-1-56581-231-4) (dontdraw propspec) isbn /bhs get 0 get 1 array astore } [0.9583] isEqual

%
% propspec + user height: multiplier on derived height through wrapper
%
{ (978-1-56581-231-4) (dontdraw propspec height=0.5) isbn /bhs get 0 get 1 array astore } [0.4792] isEqual

% AST consumption: SST profile resolves through wrapper
{ (978-1-56581-231-4) (dontdraw strictspec ast=gs1.sst2) isbn dup /strictspec get exch /xdim get 2 array astore } [true 0.660] isEqual

%
% Label text migrated to text2 framework
%

% Default ISBN label is populated as text2 content
{ (978-1-56581-231-4) (dontdraw includetext) isbn /opt get (text2) get } (ISBN 978-1-56581-231-4) isEqual

% text2 absent when includetext is off
{ (978-1-56581-231-4) (dontdraw) isbn /opt get (text2) known 1 array astore } [false] isEqual

% Default xoffset is length-dependent: -12.0 for ISBN-13 form
{ (978-1-56581-231-4) (dontdraw includetext) isbn /opt get (text2xoffset) get 1 array astore } [-12.0] isEqual

% Default xoffset is -1.0 for legacy ISBN-10
{ (1-56581-231-X) (dontdraw includetext legacy) isbn /opt get (text2xoffset) get 1 array astore } [-1.0] isEqual

% User overrides label content via text2=
{ (978-1-56581-231-4) (dontdraw includetext text2=CUSTOM) isbn /opt get (text2) get } (CUSTOM) isEqual

% extratext alias overrides label content
{ (978-1-56581-231-4) (dontdraw includetext extratext=Alt) isbn /opt get (text2) get } (Alt) isEqual

% isbntext legacy alias overrides label content
{ (978-1-56581-231-4) (dontdraw includetext isbntext=Legacy) isbn /opt get (text2) get } (Legacy) isEqual

% Legacy isbntextfont alias flows to text2font
{ (978-1-56581-231-4) (dontdraw includetext isbntextfont=Helvetica) isbn /opt get (text2font) get } (Helvetica) isEqual

% User-set xalign opts out of default xoffset injection
{ (978-1-56581-231-4) (dontdraw includetext text2xalign=center) isbn /opt get (text2xoffset) known 1 array astore } [false] isEqual

% xoffset is preserved when user supplies it alongside non-default xalign
{ (978-1-56581-231-4) (dontdraw includetext text2xalign=center text2xoffset=42) isbn /opt get (text2xoffset) get 1 array astore } [42.0] isEqual

% Smoke test: extratextcolor renders without error
{ 0 0 moveto (978-1-56581-231-4) (includetext extratextcolor=FF0000) isbn true } true isEqual

% Smoke test: extratextgaps renders without error
{ 0 0 moveto (978-1-56581-231-4) (includetext extratextgaps=2) isbn true } true isEqual
