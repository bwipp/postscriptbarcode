%

/symbol dup /uk.co.terryburton.bwipp findresource cvx def

{ (fima) (dontdraw) symbol /sbs get
} [ 2.25 2.25 2.25 11.25 2.25 11.25 2.25 2.25 2.25 ] debugIsEqual


%
% Error tests
%

{ 51 string (dontdraw) symbol } /bwipp.symbolinputTooLong isError

{ (unknown) (dontdraw) symbol } /bwipp.symbolUnknownSymbol isError

%
% Smoke test: strictspec renders without error
%
/ok_tmpl {
    { 0 0 moveto 0 0 symbol true } dup 3 -1 roll 4 exch put dup 3 -1 roll 3 exch put
    true isEqual
} def
(fima)  (strictspec xdim=0.330)  ok_tmpl
