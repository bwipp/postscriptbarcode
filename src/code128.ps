% --BEGIN ENCODER code128--
% --REQUIRES preamble loadctx unloadctx raiseerror processoptions parseinput renlinear--
% --DESC: Code 128
% --EXAM: Count01234567!
% --EXOP: includetext
% --RNDR: renlinear
/setpacking where {pop currentpacking true setpacking} if
10 dict
dup /loadctx dup /uk.co.terryburton.bwipp findresource put
dup /unloadctx dup /uk.co.terryburton.bwipp findresource put
dup /raiseerror dup /uk.co.terryburton.bwipp findresource put
dup /processoptions dup /uk.co.terryburton.bwipp findresource put
dup /parseinput dup /uk.co.terryburton.bwipp findresource put
dup /renlinear dup /uk.co.terryburton.bwipp findresource put
begin
/code128 {

    20 dict begin                  % Confine variables to local scope

    /ctx null def
    /dontdraw false def
    /includetext false def    % Enable/disable text
    /textfont /Courier def
    /textsize 10.0 def
    /textxoffset 0.0 def
    /textyoffset -7.0 def
    /height 1.0 def
    /encoding (auto) def
    /raw false def
    /parse false def
    /parsefnc false def
    /unlatchextbeforec false def    % Suppress extended ASCII with code set C
    /suppressc false def            % Suppress code set C

    //processoptions exec /options exch def
    /barcode exch def

    /code128 //loadctx exec

    % Special function characters
{
    /sta  -1 def  /stb  -2 def  /stc  -3 def
    /swa  -4 def  /swb  -5 def  /swc  -6 def
    /fn1  -7 def  /fn2  -8 def  /fn3  -9 def
    /fn4 -10 def  /sft -11 def  /stp -12 def
    /lka -13 def  /lkc -14 def  % CC-A/B and CC-C linkage
} ctxdef

    % Parse the input
    /fncvals <<
        /parse parse
        /parsefnc parsefnc
        (FNC1) fn1
        (FNC2) fn2
        (FNC3) fn3
%        (FNC4) fn4    Not user accessible as encoded automatically
        (LNKA) lka
        (LNKC) lkc
    >> def
    /msg barcode fncvals //parseinput exec def
    /msglen msg length def

    % Character maps for each state
{   % Include pseudo characters for GS1-128 Composite linkage identifiers -----------------here--v--and--v
    /seta <<fn3 96 fn2 97 sft 98 swc 99 swb 100 fn4 101 fn1 102 sta 103 stb 104 stc 105 stp 106 lka 100 lkc  99>> def
    /setb <<fn3 96 fn2 97 sft 98 swc 99 fn4 100 swa 101 fn1 102 sta 103 stb 104 stc 105 stp 106 lka  99 lkc 101>> def
    /setc <<                            swb 100 swa 101 fn1 102 sta 103 stb 104 stc 105 stp 106 lka 101 lkc 100>> def
} ctxdef

    raw {/encoding (raw) def} if

    encoding (raw) eq {
        /cws barcode length array def
        /i 0 def /j 0 def
        { % loop
            i barcode length eq {exit} if
            /cw barcode i 1 add 3 getinterval cvi def
            cws j cw put
            /i i 4 add def
            /j j 1 add def
        } loop
        /cws cws 0 j getinterval def
        /text () def
    } if

    encoding (auto) eq {

        /text msglen string def
        0 1 msglen 1 sub {
            /i exch def
            text i msg i get dup 0 lt { pop 32 } if put
        } for

        50 dict begin
                         %            Origin                    Target
                         % A0   A1   B0   B1   C0   C1
        /latch_sequence [[()   (ee) (e)  (eee)(e)  (eee)]      % A0
                         [(ee) ()   (eee)(e)  (eee)(e)  ]      % A1
                         [(d)  (ddd)()   (dd) (d)  (ddd)]      % B0
                         [(ddd)(d)  (dd) ()   (ddd)(d)  ]      % B1
                         [(c)  (eec)(c)  (ddc)()   ()   ]      % C0
                         [(eec)(c)  (ddc)(c)  ()   ()   ]] def % C1

        /latch_length   [[  0    2    1    3    1    3  ]      % A0
                         [  2    0    3    1    3    1  ]      % A1
                         [  1    3    0    2    1    3  ]      % B0
                         [  3    1    2    0    3    1  ]      % B1
                         [  1    3    1    3    0    4  ]      % C0
                         [  3    1    3    1    4    0  ]] def % C1

        /state_priority  [  2    0    4    3    1    5  ]  def % Configure encoder to conform with existing tests (baked in now)
        /start_origin    [  0    0    2    2    4    4  ]  def % Encoding starts in ASCII
        /code_set        [seta seta setb setb setc setc ]  def
        /start_code      [103    0  104    0  105    0  ]  def

        /start_length 1 def % Make room for start code
        /max_int 666 def    % Make sure state doesn't get picked

        /optimal_length [msg length {[6 {max_int} repeat]} repeat] def
        /optimal_origin [msg length {[6 {   0   } repeat]} repeat] def

        /can_a0 {c          0 ge {true} {seta c known} ifelse} def
        /can_a1 {c          0 ge {true} {seta c known} ifelse} def
        /can_b0 {c          0 ge {true} {setb c known} ifelse} def
        /can_b1 {c          0 ge {true} {setb c known} ifelse} def
        /can_c0 {num_digits 2 ge {true} {setc c known} ifelse} def
        /can_c1 {num_digits 2 ge {true} {setc c known} ifelse} def

        /int_c  {num_digits 2 ge {2} {1} ifelse} def

        /out_a0 {1 c 0 ge {c 128 ge {1 add} if c 127 and 96 ge {1 add} if} if} def
        /out_a1 {1 c 0 ge {c 128 lt {1 add} if c 127 and 96 ge {1 add} if} if} def
        /out_b0 {1 c 0 ge {c 128 ge {1 add} if c 127 and 32 lt {1 add} if} if} def
        /out_b1 {1 c 0 ge {c 128 lt {1 add} if c 127 and 32 lt {1 add} if} if} def

        /map_ab {dup 32 lt {64 add} {32 sub} ifelse} def
        /enc_a0 {1 [c 0 lt {seta c get} {c 128 ge {101} if c 127 and dup 96 ge {98 exch} if map_ab} ifelse]} def
        /enc_a1 {1 [c 0 lt {seta c get} {c 128 lt {101} if c 127 and dup 96 ge {98 exch} if map_ab} ifelse]} def
        /enc_b0 {1 [c 0 lt {setb c get} {c 128 ge {100} if c 127 and dup 32 lt {98 exch} if map_ab} ifelse]} def
        /enc_b1 {1 [c 0 lt {setb c get} {c 128 lt {100} if c 127 and dup 32 lt {98 exch} if map_ab} ifelse]} def
        /enc_c  {c 0 lt {1} {2} ifelse [c 0 lt {setc c get} {msg n 1 sub get 48 sub 10 mul msg n get 48 sub add} ifelse]} def

        /viable [{can_a0} {can_a1} {can_b0} {can_b1} {can_c0} {can_c1}] def
        /intake [{   1  } {   1  } {   1  } {   1  } {int_c } {int_c }] def
        /output [{out_a0} {out_a1} {out_b0} {out_b1} {   1  } {   1  }] def
        /encode [{enc_a0} {enc_a1} {enc_b0} {enc_b1} {enc_c } {enc_c }] def

        suppressc                      {/can_c0 {false} def} if    % Suppress C0
        suppressc unlatchextbeforec or {/can_c1 {false} def} if    % and C1 as required by options

        /get_optimal_length {
            viable state get exec {
                /m n intake state get exec sub def
                /o m 0 lt {start_origin} {optimal_origin m get} ifelse state get def
                optimal_length_n state m 0 lt {start_length} {optimal_length m get o get} ifelse
                    latch_length state get o get add output state get exec add put
            } if
        } def

        /get_optimal_origin {   % This improves performance but bakes in state_priority.
            /latch_length_s latch_length state get def
            optimal_length_n 2 get latch_length_s 2 get add             /len exch def     2
            optimal_length_n 0 get latch_length_s 0 get add dup len lt {/len exch def pop 0} {pop} ifelse
            optimal_length_n 4 get latch_length_s 4 get add dup len lt {/len exch def pop 4} {pop} ifelse
            optimal_length_n 3 get latch_length_s 3 get add dup len lt {/len exch def pop 3} {pop} ifelse
            optimal_length_n 1 get latch_length_s 1 get add dup len lt {/len exch def pop 1} {pop} ifelse
            optimal_length_n 5 get latch_length_s 5 get add dup len lt {/len exch def pop 5} {pop} ifelse
        } def

        /populate_tables {
            /num_digits 0 def
            0 1 msg length 1 sub {
                /n exch def
                /c msg n get def
                /num_digits c 48 ge c 58 lt and {num_digits 1 add} {0} ifelse def
                /optimal_length_n optimal_length n get def
                /optimal_origin_n optimal_origin n get def
                0 1 5 {/state exch def get_optimal_length} for
                0 1 5 {/state exch def optimal_origin_n state get_optimal_origin put} for
            } for
        } def

        /backtrack {
            /n msg length 1 sub def
            /optimal_length_n optimal_length n get def
            /state state_priority 0 get def
            /len optimal_length_n state get def
            state_priority 1 5 getinterval {
                dup optimal_length_n exch get dup len lt
                {/len exch def /state exch def} {pop pop} ifelse
            } forall
            len array {
                n 0 lt {exit} if
                /c msg n get def
                encode state get exec /enc exch def n exch sub /n exch def
                /latch_sequence_s latch_sequence state get def
                /state n 0 lt {start_origin} {optimal_origin n get} ifelse state get def
                dup n 0 lt {start_length} {optimal_length n get state get} ifelse
                    [latch_sequence_s state get {} forall] 3 copy putinterval length add enc putinterval
            } loop
            dup 0 start_code state get put
        } def

        populate_tables backtrack
        end
        /cws exch def /j cws length def
    } if  % auto encoding

    % Derive checksum and place stop character
    /cws j 2 add array dup 0 cws putinterval def
    /csum cws 0 get def
    1 1 j 1 sub {
        /i exch def
        /csum csum cws i get i mul add def
    } for
    /csum csum 103 mod def
    cws j csum put
    cws j 1 add seta stp get put

    options /debugcws known { /bwipp.debugcws cws //raiseerror exec } if

    % Create an array containing the character mappings
{
    /encs
    [ (212222) (222122) (222221) (121223) (121322) (131222) (122213)
      (122312) (132212) (221213) (221312) (231212) (112232) (122132)
      (122231) (113222) (123122) (123221) (223211) (221132) (221231)
      (213212) (223112) (312131) (311222) (321122) (321221) (312212)
      (322112) (322211) (212123) (212321) (232121) (111323) (131123)
      (131321) (112313) (132113) (132311) (211313) (231113) (231311)
      (112133) (112331) (132131) (113123) (113321) (133121) (313121)
      (211331) (231131) (213113) (213311) (213131) (311123) (311321)
      (331121) (312113) (312311) (332111) (314111) (221411) (431111)
      (111224) (111422) (121124) (121421) (141122) (141221) (112214)
      (112412) (122114) (122411) (142112) (142211) (241211) (221114)
      (413111) (241112) (134111) (111242) (121142) (121241) (114212)
      (124112) (124211) (411212) (421112) (421211) (212141) (214121)
      (412121) (111143) (111341) (131141) (114113) (114311) (411113)
      (411311) (113141) (114131) (311141) (411131) (211412) (211214)
      (211232) (2331112)
    ] def
} ctxdef

    % Derive space bar succession
    /sbs cws length 6 mul 1 add string def
    0 1 cws length 1 sub {
        /i exch def
        sbs i 6 mul encs cws i get get putinterval
    } for

    % Return the arguments
    <<
    /ren /renlinear
    /sbs [sbs {48 sub} forall]
    /bhs [sbs length 1 add 2 idiv {height} repeat]
    /bbs [sbs length 1 add 2 idiv {0} repeat]
    /txt [ [text textxoffset textyoffset textfont textsize] ]
    /textxalign (center)
    /opt options
    >>

    dontdraw not //renlinear if

    //unloadctx exec

    end

}
[/barcode] {null def} forall
bind def
/code128 dup load /uk.co.terryburton.bwipp defineresource pop
end
/setpacking where {pop setpacking} if
% --END ENCODER code128--
