# Biome conflicts with existing formatting
VALIDATE_BIOME_FORMAT=false
VALIDATE_BIOME_LINT=false

# Project uses own C style; covered by own CI
VALIDATE_CLANG_FORMAT=false
VALIDATE_CPP=false

# google-java-format conflicts with Checkstyle
VALIDATE_GOOGLE_JAVA_FORMAT=false

# Java linting not applicable (only a small binding example)
VALIDATE_JAVA=false

# Duplicate/noisy code detection not useful for this project
VALIDATE_JSCPD=false

# Prettier conflicts with existing formatters
VALIDATE_MARKDOWN_PRETTIER=false

# Natural language checks not useful
VALIDATE_NATURAL_LANGUAGE=false

# Black conflicts with Ruff Format; mypy fails on SWIG-generated code; Pylint duplicates Ruff
VALIDATE_PYTHON_BLACK=false
VALIDATE_PYTHON_MYPY=false
VALIDATE_PYTHON_PYLINT=false
VALIDATE_PYTHON_RUFF_FORMAT=false

# Prettier conflicts with existing formatters
VALIDATE_YAML_PRETTIER=false
